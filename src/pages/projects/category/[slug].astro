---
import { getCollection } from 'astro:content';
import { ViewTransitions } from 'astro:transitions';
import SidebarNav from '../../../components/SidebarNav.astro';
import MobileTopNav from '../../../components/MobileTopNav.astro';
import MainContent from '../../../layouts/MainContent.astro';
import ProjectGrid from '../../../components/ProjectGrid.astro';
import Category from '../../../../tina/pages/Category';
import client from '../../../../tina/__generated__/client';
import '../../../styles/global.css';

export async function getStaticPaths() {
  const allCategories = await getCollection('categories');

  return allCategories.map(category => ({
    params: { slug: category.data.categorySlug },
    props: {
      categoryData: category.data,
      categorySlug: category.data.categorySlug,
      categoryId: category.id
    }
  }));
}

const { categoryData, categorySlug, categoryId } = Astro.props;
const { slug } = Astro.params;

// Get TinaCMS data for visual editing (may fail during static build without Tina Cloud)
const relativePath = categoryId.endsWith('.mdx') ? categoryId : `${categoryId}.mdx`;
let tinaProps;
try {
  tinaProps = await client.queries.categories({ relativePath });
} catch {
  tinaProps = null;
}

// Get all projects
const allProjects = await getCollection('projects');

// Filter projects that belong to this category
// Categories are now objects with a 'category' property containing the file path
const categoryProjects = allProjects.filter(project => {
  if (!project.data.categories) return false;
  return project.data.categories.some((cat: any) => {
    // Extract slug from the category path (e.g., "src/content/categories/theatre.mdx" -> "theatre")
    const catPath = cat.category || cat;
    const catSlug = catPath.split('/').pop()?.replace('.mdx', '');
    return catSlug === slug;
  });
});

// Get homepage to determine featured project ordering
const homePage = await getCollection('pages').then(pages => pages.find(p => p.id === 'home.mdx'));
const featuredProjectOrder = (homePage?.data.featuredProjects || []).map((item: unknown, index: number) => {
  const projectPath = (item as any)?.project as string | undefined;
  const match = projectPath ? projectPath.match(/projects\/(.+)\.mdx$/) : null;
  return { slug: match ? match[1] : null, order: index };
}).filter(item => item.slug !== null);

// Featured projects are determined by the `featured` field on the project itself
const featuredProjects = categoryProjects
  .filter(p => p.data.featured === true)
  .sort((a, b) => {
    const slugA = a.id.replace(/\.mdx$/, '');
    const slugB = b.id.replace(/\.mdx$/, '');
    // Sort by homepage order if specified, otherwise by date
    const orderA = featuredProjectOrder.find(item => item.slug === slugA)?.order ?? 999;
    const orderB = featuredProjectOrder.find(item => item.slug === slugB)?.order ?? 999;
    if (orderA !== orderB) return orderA - orderB;
    // Fallback to date for featured projects not in the homepage list
    const yearA = a.data.dateCompleted ? new Date(a.data.dateCompleted).getFullYear() : 0;
    const yearB = b.data.dateCompleted ? new Date(b.data.dateCompleted).getFullYear() : 0;
    return yearB - yearA;
  });

const featuredSlugs = new Set(featuredProjects.map(p => p.id.replace(/\.mdx$/, '')));
const nonFeaturedProjects = categoryProjects.filter(p => {
  const projectSlug = p.id.replace(/\.mdx$/, '');
  return !featuredSlugs.has(projectSlug);
});

// Sort non-featured by date (newest first)
nonFeaturedProjects.sort((a, b) => {
  const yearA = a.data.dateCompleted ? new Date(a.data.dateCompleted).getFullYear() : 0;
  const yearB = b.data.dateCompleted ? new Date(b.data.dateCompleted).getFullYear() : 0;
  return yearB - yearA;
});

// Combine: featured first, then non-featured
const sortedProjects = [...featuredProjects, ...nonFeaturedProjects];
---

<!DOCTYPE html>
<html lang="en">
  <head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="Permissions-Policy" content="encrypted-media=(*)" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/favicon.ico" />
  <title>{categoryData.title} Projects - Justin Johnson</title>
  {categoryData.description && (
    <meta name="description" content={categoryData.description} />
  )}
    <ViewTransitions />
  </head>
  <body class="text-black overflow-x-hidden bg-white">
    <!-- Mobile Top Navigation -->
    <MobileTopNav />

    <!-- Sidebar Navigation -->
    <SidebarNav />

    <!-- Main Content Area -->
    <MainContent>
      <div class="p-4 md:p-6 lg:p-8">
        <div class="mb-8">
          <h1 class="text-2xl lg:text-3xl font-light mb-3">
            {categoryData.title}
          </h1>
          {categoryData.description && (
            <p class="text-lg text-gray-600 leading-relaxed">
              {categoryData.description}
            </p>
          )}
          <p class="text-sm text-gray-500 mt-4">
            {sortedProjects.length} {sortedProjects.length === 1 ? 'project' : 'projects'}
          </p>
        </div>

        <ProjectGrid projects={sortedProjects} />

        {/* TinaCMS visual editor (hidden from display, only for editing) */}
        {tinaProps && (
          <div style="display: none;">
            <!-- @ts-ignore: client:tina is an Astro client directive, not a standard prop -->
            <Category {...(tinaProps as any)} client:tina />
          </div>
        )}
      </div>
    </MainContent>

    <script>
      function initTinaVisibility() {
        // Notify parent window (TinaCMS) when page loads in iframe
        const isInIframe = window.self !== window.top;

        if (isInIframe && window.parent && window.parent !== window) {
          window.parent.postMessage({ type: 'tina:pageLoaded', url: window.location.href }, '*');
        }
      }

      // Run on initial load
      initTinaVisibility();

      // Re-run after Astro view transitions
      document.addEventListener('astro:page-load', initTinaVisibility);
    </script>
  </body>
</html>
