---
import { getCollection, type CollectionEntry } from 'astro:content';
import SidebarNav from '../../components/SidebarNav.astro';
import '../../styles/global.css';

export async function getStaticPaths() {
  const projects = await getCollection('projects');

  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

type Props = {
  project: CollectionEntry<'projects'>;
};

const { project } = Astro.props;
const { Content } = await project.render();

// Helper: split an array into chunks of the given size
const chunkArray = <T,>(array: T[], chunkSize: number): T[][] => {
  const chunks: T[][] = [];
  for (let i = 0; i < array.length; i += chunkSize) {
    chunks.push(array.slice(i, i + chunkSize));
  }
  return chunks;
};

// Decide the aspect ratio class based on the number of images in the row
const getAspectRatioClass = (count: number): string => {
  if (count === 1) return 'aspect-[16/9]';
  if (count === 2) return 'aspect-[3/2]';
  if (count === 3) return 'aspect-[4/3]';
  return 'aspect-[4/3]';
};

// Process additional images for layout
const validImages = project.data.additionalImages || [];
const n = validImages.length;
let row2Images: string[] = [];
let row3Image: string | null = null;
let remainingAlt: string[] = [];

if (n === 1) {
  row3Image = validImages[0] ?? null;
} else if (n === 2) {
  row3Image = validImages[0] ?? null;
  remainingAlt = validImages.slice(1);
} else if (n === 3) {
  row2Images = validImages.slice(0, 2);
  row3Image = validImages[2] ?? null;
} else if (n >= 4) {
  row2Images = validImages.slice(0, 3);
  row3Image = validImages[3] ?? null;
  remainingAlt = validImages.slice(4);
}

const rows = chunkArray(remainingAlt, 3);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={project.data.description || `${project.data.title} - Justin Johnson`} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{project.data.title} - Justin Johnson</title>
  </head>
  <body class="text-black overflow-x-hidden">
    <!-- Sidebar Navigation -->
    <SidebarNav currentProjectSlug={project.slug} />

    <!-- Main Content Area -->
    <main class="ml-0 md:ml-[35%] lg:ml-[30%] min-h-screen">
      <article class="p-6 md:p-8 lg:p-12 pb-16">
    <!-- HERO SECTION – Text on left, hero image on right -->
    {project.data.image && (
      <section class="grid grid-cols-1 md:grid-cols-2 gap-0 mb-0 items-stretch">
        <!-- Hero Text Container -->
        <div class="md:col-span-1 relative flex flex-col mt-6 mr-6 mb-6 ml-0">
          <!-- Main text content -->
          <div class="flex-1 flex flex-col justify-center">
            <h1 class="text-2xl md:text-3xl lg:text-4xl font-medium text-black mb-2">
              {project.data.title}
            </h1>
            {(project.data.description || (project.data.links && project.data.links.length > 0)) && (
              <div class="m-0 p-0">
                {project.data.description && (
                  <p class="mb-0 text-base text-gray-600">{project.data.description}</p>
                )}
                {project.data.links && project.data.links.length > 0 && (
                  <div class="mt-3 flex flex-wrap gap-3">
                    {project.data.links.map((link) => (
                      <a
                        href={link.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-2 px-4 py-2 border border-gray-300 hover:border-black transition-colors text-sm"
                      >
                        {link.title}
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                        </svg>
                      </a>
                    ))}
                  </div>
                )}
              </div>
            )}
          </div>
          <!-- Absolutely positioned container for categories and year -->
          <div class="absolute bottom-0 left-0 right-0 flex justify-between items-end">
            <div class="text-sm uppercase tracking-wider text-gray-600">
              {project.data.categories && project.data.categories.length > 0 ? (
                project.data.categories.map((cat) => (
                  <span class="mr-2">{cat}</span>
                ))
              ) : (
                <span>No Categories</span>
              )}
            </div>
            {project.data.yearCompleted && (
              <div class="text-sm uppercase tracking-wider text-gray-600">
                {project.data.yearCompleted}
              </div>
            )}
          </div>
        </div>
        <!-- Hero Image Column -->
        <a
          href={project.data.image}
          data-lightbox="gallery"
          class="md:col-span-1 block group p-0 m-0"
        >
          <div class="relative min-h-[350px] h-full">
            <img
              src={project.data.image}
              alt={project.data.title}
              class="absolute inset-0 w-full h-full object-cover transition-all duration-300"
            />
            <!-- White overlay on hover -->
            <div class="absolute inset-0 bg-white/30 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          </div>
        </a>
      </section>
    )}

    <!-- Render Row 2 if defined (first 2-3 additional images) -->
    {row2Images.length > 0 && (
      <section class="grid gap-0 mb-0">
        <div class={`grid gap-0 ${
          row2Images.length === 1 ? 'grid-cols-1' :
          row2Images.length === 2 ? 'grid-cols-2' : 'grid-cols-3'
        }`}>
          {row2Images.map((image, index) => (
            <a
              href={image}
              data-lightbox="gallery"
              class="block group p-0 m-0"
            >
              <div class={`relative ${getAspectRatioClass(row2Images.length)}`}>
                <img
                  src={image}
                  alt={`${project.data.title} image ${index + 1}`}
                  class="absolute inset-0 w-full h-full object-cover transition-all duration-300 group-hover:opacity-90"
                />
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Render Row 3: Single alternate image with body text -->
    {row3Image && (
      <section class="grid grid-cols-1 md:grid-cols-2 gap-0 items-stretch mb-0">
        <a
          href={row3Image}
          data-lightbox="gallery"
          class="block group p-0 m-0 relative h-full min-h-[350px]"
        >
          <img
            src={row3Image}
            alt={`${project.data.title} secondary image`}
            class="absolute inset-0 w-full h-full object-cover transition-all duration-300 group-hover:opacity-90"
          />
        </a>
        <div class="order-2 prose prose-base max-w-none text-gray-700 mt-1 mb-1 ml-2 -mr-4">
          <Content />
        </div>
      </section>
    )}

    <!-- Render Remaining Alternating Rows -->
    {rows.map((row) => {
      const gridColsClass =
        row.length === 1 ? 'grid-cols-1' :
        row.length === 2 ? 'grid-cols-2' : 'grid-cols-3';
      return (
        <section class="grid gap-0 mb-0">
          <div class={`grid ${gridColsClass} gap-0`}>
            {row.map((image, colIdx) => (
              <a
                href={image}
                data-lightbox="gallery"
                class="block group p-0 m-0"
              >
                <div class={`relative ${getAspectRatioClass(row.length)}`}>
                  <img
                    src={image}
                    alt={`${project.data.title} image`}
                    class="absolute inset-0 w-full h-full object-cover transition-all duration-300 group-hover:opacity-90"
                  />
                </div>
              </a>
            ))}
          </div>
        </section>
      );
    })}

    <!-- Back to projects link -->
    <div class="border-t border-gray-200 pt-8 mt-8">
      <a
        href="/"
        class="inline-flex items-center text-blue-600 hover:text-blue-800 font-medium transition-colors p-0 m-0"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5 mr-2"
          viewBox="0 0 20 20"
          fill="currentColor"
        >
          <path
            fill-rule="evenodd"
            d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z"
            clip-rule="evenodd"
          />
        </svg>
        Back to all projects
      </a>
    </div>
      </article>
    </main>

<!-- Lightbox functionality -->
<script>
  // Simple lightbox implementation
  document.addEventListener('DOMContentLoaded', () => {
    const galleryLinks = document.querySelectorAll('a[data-lightbox="gallery"]');

    if (galleryLinks.length === 0) return;

    // Create lightbox elements
    const lightbox = document.createElement('div');
    lightbox.className = 'lightbox';
    lightbox.innerHTML = `
      <button class="lightbox-close" aria-label="Close lightbox">&times;</button>
      <button class="lightbox-prev" aria-label="Previous image">&#8249;</button>
      <button class="lightbox-next" aria-label="Next image">&#8250;</button>
      <img class="lightbox-image" src="" alt="">
      <div class="lightbox-counter"></div>
    `;
    document.body.appendChild(lightbox);

    const lightboxImg = lightbox.querySelector('.lightbox-image') as HTMLImageElement;
    const closeBtn = lightbox.querySelector('.lightbox-close') as HTMLButtonElement;
    const prevBtn = lightbox.querySelector('.lightbox-prev') as HTMLButtonElement;
    const nextBtn = lightbox.querySelector('.lightbox-next') as HTMLButtonElement;
    const counter = lightbox.querySelector('.lightbox-counter') as HTMLDivElement;

    const images = Array.from(galleryLinks).map(link => ({
      src: link.getAttribute('href') || '',
      alt: link.querySelector('img')?.getAttribute('alt') || ''
    }));

    let currentIndex = 0;

    const showImage = (index: number) => {
      currentIndex = index;
      lightboxImg.src = images[index].src;
      lightboxImg.alt = images[index].alt;
      counter.textContent = `${index + 1} / ${images.length}`;
      lightbox.classList.add('active');
      document.body.style.overflow = 'hidden';
    };

    const hideImage = () => {
      lightbox.classList.remove('active');
      document.body.style.overflow = '';
    };

    const showNext = () => {
      currentIndex = (currentIndex + 1) % images.length;
      showImage(currentIndex);
    };

    const showPrev = () => {
      currentIndex = (currentIndex - 1 + images.length) % images.length;
      showImage(currentIndex);
    };

    // Event listeners
    galleryLinks.forEach((link, index) => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        showImage(index);
      });
    });

    closeBtn.addEventListener('click', hideImage);
    prevBtn.addEventListener('click', showPrev);
    nextBtn.addEventListener('click', showNext);

    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) hideImage();
    });

    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
      if (!lightbox.classList.contains('active')) return;

      if (e.key === 'Escape') hideImage();
      if (e.key === 'ArrowRight') showNext();
      if (e.key === 'ArrowLeft') showPrev();
    });
  });
</script>

<style>
  /* Remove default margins and gaps */
  section {
    margin: 0;
    padding: 0;
  }

  /* Custom prose styles for project content */
  .prose {
    color: #374151;
    line-height: 1.7;
    padding: 1.5rem;
  }

  .prose h1,
  .prose h2,
  .prose h3,
  .prose h4 {
    color: #111827;
    font-weight: 400;
  }

  .prose h2 {
    margin-top: 2rem;
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }

  .prose h3 {
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    font-size: 1.25rem;
  }

  .prose p {
    margin-bottom: 1rem;
  }

  .prose a {
    color: #2563eb;
    text-decoration: underline;
  }

  .prose a:hover {
    color: #1e40af;
  }

  .prose strong {
    font-weight: 600;
  }

  .prose em {
    font-style: italic;
  }

  .prose pre {
    background-color: #f9fafb;
    border-radius: 0.5rem;
    padding: 1rem;
    overflow-x: auto;
    font-size: 0.875rem;
    line-height: 1.7;
    margin: 1rem 0;
  }

  .prose code {
    background-color: #f3f4f6;
    padding: 0.125rem 0.25rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
  }

  .prose pre code {
    background-color: transparent;
    padding: 0;
  }

  /* Image grid layouts with no gaps */
  .grid {
    display: grid;
    gap: 0;
  }

  .grid img {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* Aspect ratio utilities */
  .aspect-\[16\/9\] {
    aspect-ratio: 16 / 9;
  }

  .aspect-\[3\/2\] {
    aspect-ratio: 3 / 2;
  }

  .aspect-\[4\/3\] {
    aspect-ratio: 4 / 3;
  }

  /* Ensure images fill their containers */
  img {
    display: block;
  }

  a[data-lightbox] {
    cursor: zoom-in;
  }

  /* Related projects styles */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Lightbox styles */
  :global(.lightbox) {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.95);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  :global(.lightbox.active) {
    opacity: 1;
    visibility: visible;
  }

  :global(.lightbox-image) {
    max-width: 90%;
    max-height: 90%;
    object-fit: contain;
  }

  :global(.lightbox-close),
  :global(.lightbox-prev),
  :global(.lightbox-next) {
    position: absolute;
    background: rgba(255, 255, 255, 0.9);
    border: none;
    color: #000;
    font-size: 2rem;
    cursor: pointer;
    padding: 0.5rem 1rem;
    transition: background 0.2s ease;
    z-index: 10000;
  }

  :global(.lightbox-close):hover,
  :global(.lightbox-prev):hover,
  :global(.lightbox-next):hover {
    background: #fff;
  }

  :global(.lightbox-close) {
    top: 1rem;
    right: 1rem;
    font-size: 3rem;
    line-height: 1;
    padding: 0.25rem 0.75rem;
  }

  :global(.lightbox-prev) {
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
  }

  :global(.lightbox-next) {
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
  }

  :global(.lightbox-counter) {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(255, 255, 255, 0.9);
    color: #000;
    padding: 0.5rem 1rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
    font-weight: 500;
  }
</style>
  </body>
</html>
