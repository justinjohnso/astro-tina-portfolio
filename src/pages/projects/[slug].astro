---
import { getCollection, type CollectionEntry } from 'astro:content';
import SidebarNav from '../../components/SidebarNav.astro';
import MobileTopNav from '../../components/MobileTopNav.astro';
import MainContent from '../../layouts/MainContent.astro';
import { getEmbedInfo } from '../../utils/embedUtils';
import { extractCategorySlug } from '../../utils/categoryUtils';
import '../../styles/global.css';
import client from '../../../tina/__generated__/client';
import Project from '../../../tina/pages/Project';
import { ViewTransitions } from 'astro:transitions';

export async function getStaticPaths() {
  const projects = await getCollection('projects');

  return projects.map((project) => ({
    // Remove .mdx extension from slug for clean URLs
    params: { slug: project.id.replace(/\.mdx$/, '') },
    props: {
      project,
      getTinaProps: async () => {
        // Use tinaInfo if available (new loader), otherwise use id (which already includes .mdx)
        const relativePath = project.data.tinaInfo?.relativePath || project.id;
        return client.queries.projects({
          relativePath: relativePath,
        });
      },
    },
  }));
}

type Props = {
  project: CollectionEntry<'projects'>;
  getTinaProps: () => Promise<any>;
};

const { project, getTinaProps } = Astro.props;
const tinaProps = await getTinaProps();
const { Content } = await project.render();

// Get category metadata for display names
const allCategories = await getCollection('categories');
const categoryMetadata = new Map(
  allCategories.map(cat => [cat.data.categorySlug, cat.data])
);

// Get display names for project categories
const categoryDisplayNames = project.data.categories?.map((cat: any) => {
  const catSlug = extractCategorySlug(cat);
  if (!catSlug) return null;
  const catData = categoryMetadata.get(catSlug);
  return catData?.title || catSlug;
}).filter(Boolean) || [];

// Check for media embed - trim whitespace/newlines that might come from YAML formatting
const embedInfo = project.data.mediaEmbed ? getEmbedInfo(project.data.mediaEmbed.trim()) : null;

// Helper: split an array into chunks of the given size
const chunkArray = <T,>(array: T[], chunkSize: number): T[][] => {
  const chunks: T[][] = [];
  for (let i = 0; i < array.length; i += chunkSize) {
    chunks.push(array.slice(i, i + chunkSize));
  }
  return chunks;
};

// Decide the aspect ratio class based on the number of images in the row
const getAspectRatioClass = (count: number): string => {
  if (count === 1) return 'aspect-[16/9]';
  if (count === 2) return 'aspect-[3/2]';
  if (count === 3) return 'aspect-[4/3]';
  return 'aspect-[4/3]';
};

// Process additional images for layout
const validImages = (project.data.additionalImages || []).map(item => 
  typeof item === 'string' ? item : item.image
);
const n = validImages.length;

// Check if we have a media embed (video or SoundCloud) that affects layout
const hasMediaEmbed = embedInfo !== null;

let row2Images: string[] = [];
let row3Image: string | null = null;
let remainingImages: string[] = [];

if (hasMediaEmbed) {
  // When media embed present: row 2 is image+text, media embed is row 3, then remaining images from row 4+
  // Special case: if only 1 image, don't put it with text - treat as normal layout
  if (n === 1) {
    // With 1 image + media: hero row has text+image, row 2 has media embed
    row3Image = null;
    remainingImages = [];
  } else {
    // With 2+ images: first image goes with body text in row 2, media in row 3, rest after
    row3Image = validImages[0] ?? null;
    remainingImages = validImages.slice(1);
  }
} else {
  // No media embed: standard layout with row 2 images, row 3 image+text, row 4+ remaining
  if (n === 1) {
    row3Image = validImages[0] ?? null;
  } else if (n === 2) {
    row3Image = validImages[0] ?? null;
    remainingImages = validImages.slice(1);
  } else if (n === 3) {
    row2Images = validImages.slice(0, 2);
    row3Image = validImages[2] ?? null;
  } else if (n === 4) {
    // For exactly 4 images: row 2 gets 1 image with text, row 3 gets 3 images
    row3Image = validImages[0] ?? null;
    row2Images = validImages.slice(1, 4);
  } else if (n >= 5) {
    row2Images = validImages.slice(0, 3);
    row3Image = validImages[3] ?? null;
    remainingImages = validImages.slice(4);
  }
}

// Chunk remainingImages into rows of 3
const rows = chunkArray(remainingImages, 3);
---

<!DOCTYPE html>
<html lang="en" style="scroll-behavior: smooth;">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={project.data.description || `${project.data.title} - Justin Johnson`} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{project.data.title} - Justin Johnson</title>
    <ViewTransitions />
  </head>
  <body class="text-black overflow-x-hidden bg-white">
    <!-- Mobile Top Navigation -->
    <MobileTopNav />

    <!-- Sidebar Navigation -->
    <SidebarNav currentProjectSlug={project.slug} />

    <!-- Main Content Area -->
    <MainContent>
      <!-- TinaCMS Visual Editor Component (only renders in TinaCMS iframe) -->
      <div id="tina-wrapper" style="display: none;">
        <!-- @ts-ignore: client:tina is an Astro directive, not a prop type -->
        <Project {...(tinaProps as any)} client:tina />
      </div>

      <!-- Static content (hidden when in TinaCMS iframe) -->
      <article id="static-content" class="p-4 md:p-6 lg:p-8 pb-12">
    <!-- HERO SECTION -->
    {project.data.image && (
      <>
        {/* If only hero image (no additional images) AND no media embed, stack vertically at full width */}
        {validImages.length === 0 && !hasMediaEmbed ? (
          <>
            {/* Hero Text - Full Width */}
            <section class="mb-2">
              <div class="flex flex-col pb-6">
                <h1 class="text-2xl lg:text-3xl font-light text-black mb-2">
                  {project.data.title}
                </h1>

                {/* Year */}
                {project.data.dateCompleted && (
                  <p class="text-base text-gray-600 mb-1">{new Date(project.data.dateCompleted).getFullYear()}</p>
                )}

                {/* Categories with display names */}
                {categoryDisplayNames.length > 0 && (
                  <p class="text-base text-gray-600 mb-3">{categoryDisplayNames.join(', ')}</p>
                )}

                {/* Description */}
                {project.data.description && (
                  <p class="text-base text-gray-600 mb-3 whitespace-pre-line">{project.data.description}</p>
                )}

                {/* Links */}
                <div class="flex flex-wrap gap-3">
                  {/* Media embed link */}
                  {embedInfo && (
                    <a
                      href="#media-embed"
                      class="inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-300 hover:border-black transition-colors text-sm"
                    >
                      {embedInfo.type === 'soundcloud' || embedInfo.type === 'audio' ? 'Listen' : 'Watch'}
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                      </svg>
                    </a>
                  )}
                  
                  {/* External links */}
                  {project.data.links && project.data.links.map((link) => (
                    <a
                      href={link.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-300 hover:border-black transition-colors text-sm"
                    >
                      {link.title}
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                      </svg>
                    </a>
                  ))}
                </div>
              </div>
            </section>

            {/* Hero Image - Full Width */}
            <section class="mb-2">
              <a
                href={project.data.image}
                data-lightbox="gallery"
                class="block group relative overflow-hidden min-h-[350px]"
              >
                <img
                  src={project.data.image}
                  alt={project.data.title}
                  class="w-full h-full object-cover transition-all duration-300"
                />
                <!-- White overlay on hover -->
                <div class="absolute inset-0 bg-white/30 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
              </a>
            </section>
          </>
        ) : (
          /* Default: Text on left, hero image on right */
          <section class="grid grid-cols-1 md:grid-cols-2 gap-2 mb-2 items-start">
            {/* Hero Text Container */}
            <div class="md:col-span-1 relative flex flex-col md:min-h-[350px]">
              {/* Main text content */}
              <div class="flex-1 flex flex-col pb-6 md:pr-6">
                <h1 class="text-2xl lg:text-3xl font-light text-black mb-2">
                  {project.data.title}
                </h1>

                {/* Year */}
                {project.data.dateCompleted && (
                  <p class="text-base text-gray-600 mb-1">{new Date(project.data.dateCompleted).getFullYear()}</p>
                )}

                {/* Categories with display names */}
                {categoryDisplayNames.length > 0 && (
                  <p class="text-base text-gray-600 mb-3">{categoryDisplayNames.join(', ')}</p>
                )}

                {/* Description */}
                {project.data.description && (
                  <p class="text-base text-gray-600 mb-3 whitespace-pre-line">{project.data.description}</p>
                )}

                {/* Links */}
                <div class="flex flex-wrap gap-3">
                  {/* Media embed link */}
                  {embedInfo && (
                    <a
                      href="#media-embed"
                      class="inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-300 hover:border-black transition-colors text-sm"
                    >
                      {embedInfo.type === 'soundcloud' || embedInfo.type === 'audio' ? 'Listen' : 'Watch'}
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                      </svg>
                    </a>
                  )}
                  
                  {/* External links */}
                  {project.data.links && project.data.links.map((link) => (
                    <a
                      href={link.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-300 hover:border-black transition-colors text-sm"
                    >
                      {link.title}
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                      </svg>
                    </a>
                  ))}
                </div>
              </div>
            </div>

            {/* Hero Image Column */}
            <a
              href={project.data.image}
              data-lightbox="gallery"
              class="md:col-span-1 block group relative overflow-hidden h-full min-h-[250px] md:min-h-[350px]"
            >
              <img
                src={project.data.image}
                alt={project.data.title}
                class="absolute inset-0 w-full h-full object-cover transition-all duration-300"
              />
              {/* White overlay on hover */}
              <div class="absolute inset-0 bg-white/30 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            </a>
          </section>
        )}
      </>
    )}

    <!-- Render Row 2: Image with body text (when media embed present) -->
    {row3Image && (
      <section class="grid grid-cols-1 md:grid-cols-2 gap-2 items-stretch mb-2">
        <a
          href={row3Image}
          data-lightbox="gallery"
          class="block group p-0 m-0 relative h-full min-h-[350px]"
        >
          <img
            src={row3Image}
            alt={`${project.data.title} secondary image`}
            class="absolute inset-0 w-full h-full object-cover transition-all duration-300 group-hover:opacity-90"
          />
        </a>
        <div class="order-2 prose prose-base max-w-none text-gray-700 mt-1 mb-1 ml-2 -mr-4">
          <Content />
        </div>
      </section>
    )}

    <!-- Render Row 3: Additional images grid if no media embed -->
    {!hasMediaEmbed && row2Images.length > 0 && (
      <section class="grid gap-2 mb-2">
        <div class={`grid gap-2 ${
          row2Images.length === 1 ? 'grid-cols-1' :
          row2Images.length === 2 ? 'grid-cols-2' : 'grid-cols-3'
        }`}>
          {row2Images.map((image, index) => (
            <a
              href={image}
              data-lightbox="gallery"
              class="block group p-0 m-0"
            >
              <div class={`relative ${getAspectRatioClass(row2Images.length)}`}>
                <img
                  src={image}
                  alt={`${project.data.title} image ${index + 1}`}
                  class="absolute inset-0 w-full h-full object-cover transition-all duration-300 group-hover:opacity-90"
                />
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Render Row 3: Media embed (video, SoundCloud, or audio) full width -->
    {embedInfo && embedInfo.type === 'soundcloud' && (
      <section class="mb-2" id="media-embed">
        <div class="relative w-full min-h-[350px]">
          <iframe
            width="100%"
            height="100%"
            scrolling="no"
            frameborder="no"
            allow="autoplay"
            src={embedInfo.embedUrl}
            title={project.data.title}
            class="min-h-[350px]"
          ></iframe>
        </div>
      </section>
    )}

    {embedInfo && embedInfo.type === 'audio' && (
      <section class="mb-2" id="media-embed">
        <div class="relative w-full flex items-center justify-center py-8">
          <audio
            controls
            class="w-full"
            preload="metadata"
          >
            <source src={embedInfo.embedUrl} type="audio/mpeg" />
            Your browser does not support the audio element.
          </audio>
        </div>
      </section>
    )}

    {embedInfo && embedInfo.type !== 'soundcloud' && embedInfo.type !== 'audio' && (
      <section class="mb-2" id="media-embed">
        <div class="relative w-full min-h-[350px]">
          <iframe
            src={embedInfo.embedUrl}
            style={`aspect-ratio: ${embedInfo.aspectRatio}`}
            class="w-full h-full min-h-[350px]"
            frameborder="0"
            allow="autoplay; fullscreen; picture-in-picture; clipboard-write"
            allowfullscreen
            title={project.data.title}
          ></iframe>
        </div>
      </section>
    )}

    <!-- Render Remaining Rows (3 per row) -->
    {rows.map((row) => {
      const gridColsClass =
        row.length === 1 ? 'grid-cols-1' :
        row.length === 2 ? 'grid-cols-2' : 'grid-cols-3';
      return (
        <section class="grid gap-2 mb-2">
          <div class={`grid ${gridColsClass} gap-2`}>
            {row.map((image, colIdx) => (
              <a
                href={image}
                data-lightbox="gallery"
                class="block group p-0 m-0"
              >
                <div class={`relative ${getAspectRatioClass(row.length)}`}>
                  <img
                    src={image}
                    alt={`${project.data.title} image`}
                    class="absolute inset-0 w-full h-full object-cover transition-all duration-300 group-hover:opacity-90"
                  />
                </div>
              </a>
            ))}
          </div>
        </section>
      );
    })}

      </article>
    </MainContent>

<!-- Lightbox functionality -->
<script>
  function initLightbox() {
    // Remove any existing lightbox first
    const existingLightbox = document.querySelector('.lightbox');
    if (existingLightbox) {
      existingLightbox.remove();
    }

    const galleryLinks = document.querySelectorAll('a[data-lightbox="gallery"]');

    if (galleryLinks.length === 0) return;

    // Create lightbox elements
    const lightbox = document.createElement('div');
    lightbox.className = 'lightbox';
    lightbox.innerHTML = `
      <button class="lightbox-close" aria-label="Close lightbox">&times;</button>
      <button class="lightbox-prev" aria-label="Previous image">&#8249;</button>
      <button class="lightbox-next" aria-label="Next image">&#8250;</button>
      <img class="lightbox-image" src="" alt="">
      <div class="lightbox-counter"></div>
    `;
    document.body.appendChild(lightbox);

    const lightboxImg = lightbox.querySelector('.lightbox-image') as HTMLImageElement;
    const closeBtn = lightbox.querySelector('.lightbox-close') as HTMLButtonElement;
    const prevBtn = lightbox.querySelector('.lightbox-prev') as HTMLButtonElement;
    const nextBtn = lightbox.querySelector('.lightbox-next') as HTMLButtonElement;
    const counter = lightbox.querySelector('.lightbox-counter') as HTMLDivElement;

    const images = Array.from(galleryLinks).map(link => ({
      src: link.getAttribute('href') || '',
      alt: link.querySelector('img')?.getAttribute('alt') || ''
    }));

    let currentIndex = 0;

    const showImage = (index: number) => {
      currentIndex = index;
      lightboxImg.src = images[index].src;
      lightboxImg.alt = images[index].alt;
      counter.textContent = `${index + 1} / ${images.length}`;
      lightbox.classList.add('active');
      document.body.style.overflow = 'hidden';
    };

    const hideImage = () => {
      lightbox.classList.remove('active');
      document.body.style.overflow = '';
    };

    const showNext = () => {
      currentIndex = (currentIndex + 1) % images.length;
      showImage(currentIndex);
    };

    const showPrev = () => {
      currentIndex = (currentIndex - 1 + images.length) % images.length;
      showImage(currentIndex);
    };

    // Event listeners
    galleryLinks.forEach((link, index) => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        showImage(index);
      });
    });

    closeBtn.addEventListener('click', hideImage);
    prevBtn.addEventListener('click', showPrev);
    nextBtn.addEventListener('click', showNext);

    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) hideImage();
    });

    // Keyboard navigation
    const handleKeydown = (e: KeyboardEvent) => {
      if (!lightbox.classList.contains('active')) return;

      if (e.key === 'Escape') hideImage();
      if (e.key === 'ArrowRight') showNext();
      if (e.key === 'ArrowLeft') showPrev();
    };

    document.addEventListener('keydown', handleKeydown);
  }

  // Initialize on first load
  initLightbox();

  // Re-initialize after Astro view transitions
  document.addEventListener('astro:page-load', initLightbox);
</script>

<style>
  /* Reset default padding only */
  section {
    padding: 0;
  }

  /* Custom prose styles for project content */
  .prose {
    color: #374151;
    line-height: 1.7;
    padding: 1.5rem;
  }

  .prose h1,
  .prose h2,
  .prose h3,
  .prose h4 {
    color: #111827;
    font-weight: 400;
  }

  .prose h2 {
    margin-top: 2rem;
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }

  .prose h3 {
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    font-size: 1.25rem;
  }

  .prose p {
    margin-bottom: 1rem;
  }

  .prose a {
    color: #2563eb;
    text-decoration: underline;
  }

  .prose a:hover {
    color: #1e40af;
  }

  .prose strong {
    font-weight: 600;
  }

  .prose em {
    font-style: italic;
  }

  .prose pre {
    background-color: #f9fafb;
    border-radius: 0.5rem;
    padding: 1rem;
    overflow-x: auto;
    font-size: 0.875rem;
    line-height: 1.7;
    margin: 1rem 0;
  }

  .prose code {
    background-color: #f3f4f6;
    padding: 0.125rem 0.25rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
  }

  .prose pre code {
    background-color: transparent;
    padding: 0;
  }

  /* Image grid layouts */
  .grid {
    display: grid;
  }

  .grid img {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* Aspect ratio utilities */
  .aspect-\[16\/9\] {
    aspect-ratio: 16 / 9;
  }

  .aspect-\[3\/2\] {
    aspect-ratio: 3 / 2;
  }

  .aspect-\[4\/3\] {
    aspect-ratio: 4 / 3;
  }

  /* Ensure images fill their containers */
  img {
    display: block;
  }

  a[data-lightbox] {
    cursor: zoom-in;
  }

  /* Related projects styles */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Lightbox styles */
  :global(.lightbox) {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.95);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  :global(.lightbox.active) {
    opacity: 1;
    visibility: visible;
  }

  :global(.lightbox-image) {
    max-width: 90%;
    max-height: 90%;
    object-fit: contain;
  }

  :global(.lightbox-close),
  :global(.lightbox-prev),
  :global(.lightbox-next) {
    position: absolute;
    background: rgba(255, 255, 255, 0.9);
    border: none;
    color: #000;
    font-size: 2rem;
    cursor: pointer;
    padding: 0.5rem 1rem;
    transition: background 0.2s ease;
    z-index: 10000;
  }

  :global(.lightbox-close):hover,
  :global(.lightbox-prev):hover,
  :global(.lightbox-next):hover {
    background: #fff;
  }

  :global(.lightbox-close) {
    top: 1rem;
    right: 1rem;
    font-size: 3rem;
    line-height: 1;
    padding: 0.25rem 0.75rem;
  }

  :global(.lightbox-prev) {
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
  }

  :global(.lightbox-next) {
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
  }

  :global(.lightbox-counter) {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(255, 255, 255, 0.9);
    color: #000;
    padding: 0.5rem 1rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
    font-weight: 500;
  }
</style>

<script>
  function initTinaVisibility() {
    // Detect if we're in TinaCMS iframe and show appropriate content
    // TinaCMS handles routing automatically via ui.router configuration
    const isInIframe = window.self !== window.top;
    const tinaWrapper = document.getElementById('tina-wrapper');
    const staticContent = document.getElementById('static-content');

    if (isInIframe) {
      // In TinaCMS: show visual editor component, hide static content
      if (tinaWrapper) tinaWrapper.style.display = 'block';
      if (staticContent) staticContent.style.display = 'none';

      // Notify parent window (TinaCMS) that we've loaded a new page
      if (window.parent && window.parent !== window) {
        window.parent.postMessage({ type: 'tina:pageLoaded', url: window.location.href }, '*');
      }
    } else {
      // Production: hide visual editor, show static content
      if (tinaWrapper) tinaWrapper.style.display = 'none';
      if (staticContent) staticContent.style.display = 'block';
    }
  }

  // Run on initial load
  initTinaVisibility();

  // Re-run after Astro view transitions
  document.addEventListener('astro:page-load', initTinaVisibility);
</script>
  </body>
</html>
