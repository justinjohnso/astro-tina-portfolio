---
import { getCollection, type CollectionEntry } from 'astro:content';
import { ViewTransitions } from 'astro:transitions';
import client from '../../../tina/__generated__/client';

export async function getStaticPaths() {
  const posts = await getCollection('posts');

return posts.map((post) => ({
params: { slug: post.id.replace(/\.mdx$/, '') },
  props: {
      post,
      getTinaProps: async () => {
        // Use tinaInfo if available (new loader), otherwise use id (which already includes .mdx)
      const relativePath = post.data.tinaInfo?.relativePath || post.id;
        return client.queries.posts({
          relativePath: relativePath,
        });
      },
    },
  }));
}

type Props = {
  post: CollectionEntry<'posts'>;
  getTinaProps: () => Promise<any>;
};

const { post, getTinaProps } = Astro.props;
const tinaProps = await getTinaProps();

// Use TinaCMS content if available, otherwise fallback to basic rendering
let Content: any = null;
let contentText = '';

// Handle content rendering for TinaCMS-managed posts
// For now, we'll use a simplified approach since posts are TinaCMS-managed
Content = () => null; // Placeholder - proper TinaCMS component needed
contentText = tinaProps?.data?.posts?.body || '';

// Get category metadata for display names
const allCategories = await getCollection('categories');
const categoryMetadata = new Map(
  allCategories.map(cat => [cat.data.categorySlug, cat.data])
);

// Get display names for post categories
const categoryDisplayNames = post.data.categories?.map(catSlug => {
  const catData = categoryMetadata.get(catSlug);
  return (catData as any)?.title || catSlug;
}) || [];

// Format date - use publishedAt from TinaCMS schema or fallback to date
const dateToUse = post.data.publishedAt || post.data.date;
const formattedDate = dateToUse ? new Date(dateToUse).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
}) : 'Draft';

// Calculate reading time (rough estimate: 200 words per minute)
const wordCount = contentText.split(/\s+/).length;
const readingTime = wordCount > 0 ? Math.ceil(wordCount / 200) : 1;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={post.data.description || `${post.data.title} - Blog post by Justin Johnson`} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{post.data.title} - Justin Johnson</title>
    <ViewTransitions />
  </head>
  <body class="text-black bg-white">
    <main class="max-w-3xl mx-auto px-4 py-8 md:py-12">
      <!-- Navigation -->
      <nav class="mb-8">
        <a href="/blog" class="text-sm hover:underline">← Back to Blog</a>
      </nav>

      <!-- Article Header -->
      <header class="mb-8">
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-medium mb-4">
          {post.data.title}
        </h1>

        <div class="flex flex-wrap items-center gap-4 text-sm text-gray-600 mb-4">
          <time datetime={post.data.date}>
            {formattedDate}
          </time>

          <span>·</span>

          <span>{readingTime} min read</span>

          {categoryDisplayNames.length > 0 && (
            <>
              <span>·</span>
              <span class="flex gap-2">
                {categoryDisplayNames.map((cat) => (
                  <span class="px-2 py-1 bg-gray-100 rounded text-xs">
                    {cat}
                  </span>
                ))}
              </span>
            </>
          )}
        </div>

        {post.data.description && (
          <p class="text-lg text-gray-700">
            {post.data.description}
          </p>
        )}
      </header>

      <!-- Article Content -->
      <article class="prose prose-lg max-w-none">
        <Content />
      </article>

      <!-- Article Footer -->
      <footer class="mt-12 pt-8 border-t border-gray-200">
        <div class="flex justify-between items-center">
          <a
            href="/blog"
            class="text-sm text-gray-600 hover:text-black"
          >
            ← Back to all posts
          </a>

          <a
            href="/#contact"
            class="text-sm text-gray-600 hover:text-black"
          >
            Get in touch →
          </a>
        </div>
      </footer>
    </main>
  </body>
</html>

<style>
  /* Enhanced prose styles for blog content */
  .prose {
    color: #374151;
    line-height: 1.75;
  }

  .prose h1,
  .prose h2,
  .prose h3,
  .prose h4 {
    color: #111827;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .prose h2 {
    font-size: 1.875rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #e5e7eb;
  }

  .prose h3 {
    font-size: 1.5rem;
  }

  .prose h4 {
    font-size: 1.25rem;
  }

  .prose p {
    margin-bottom: 1.5rem;
  }

  .prose a {
    color: #2563eb;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose a:hover {
    color: #1e40af;
  }

  .prose strong {
    font-weight: 600;
    color: #111827;
  }

  .prose em {
    font-style: italic;
  }

  .prose ul,
  .prose ol {
    margin: 1.5rem 0;
    padding-left: 1.5rem;
  }

  .prose li {
    margin-bottom: 0.5rem;
  }

  .prose blockquote {
    border-left: 4px solid #e5e7eb;
    padding-left: 1rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: #6b7280;
  }

  .prose pre {
    background-color: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
    padding: 1rem;
    overflow-x: auto;
    font-size: 0.875rem;
    line-height: 1.7;
    margin: 1.5rem 0;
  }

  .prose code {
    background-color: #f3f4f6;
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
    font-family: 'Monaco', 'Courier New', monospace;
  }

  .prose pre code {
    background-color: transparent;
    padding: 0;
  }

  .prose img {
    border-radius: 0.5rem;
    margin: 2rem 0;
  }

  .prose hr {
    border: none;
    border-top: 1px solid #e5e7eb;
    margin: 3rem 0;
  }

  .prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
  }

  .prose th,
  .prose td {
    border: 1px solid #e5e7eb;
    padding: 0.75rem;
    text-align: left;
  }

  .prose th {
    background-color: #f9fafb;
    font-weight: 600;
  }
</style>
