---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { ViewTransitions } from 'astro:transitions';

// Get all blog posts, sorted by date (newest first)
const posts = (await getCollection('posts')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<!DOCTYPE html>
<html lang="en">
  <head>
  <meta charset="UTF-8" />
  <meta name="description" content="Blog posts about interactive technology, sound design, and physical computing by Justin Johnson" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="Permissions-Policy" content="encrypted-media=(*)" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/favicon.ico" />
  <title>Blog - Justin Johnson</title>
    <ViewTransitions />
  </head>
  <body class="text-black bg-white">
    <main class="max-w-4xl mx-auto px-4 py-8 md:py-12">
      <!-- Header -->
      <header class="mb-12">
        <nav class="mb-8">
          <a href="/" class="text-sm hover:underline">← Back to Home</a>
        </nav>
        <h1 class="text-4xl md:text-5xl font-medium mb-4">Blog</h1>
        <p class="text-lg text-gray-600">
          Weekly updates from my work at NYU ITP exploring interactive technology, sound design, and physical computing.
        </p>
      </header>

      <!-- Blog Posts List -->
      <div class="space-y-12">
        {posts.map((post) => {
          const slug = post.id.replace(/\.mdx$/, '');
          return (
            <article class="border-b border-gray-200 pb-8">
              <a href={`/blog/${slug}`} class="group">
                <h2 class="text-2xl md:text-3xl font-medium mb-2 group-hover:underline">
                  {post.data.title}
                </h2>
              </a>

              <div class="flex items-center gap-4 text-sm text-gray-600 mb-4">
                <time datetime={post.data.date}>
                  {new Date(post.data.date).toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric'
                  })}
                </time>

                {post.data.categories && post.data.categories.length > 0 && (
                  <span class="flex gap-2">
                    {post.data.categories.map((cat) => (
                      <span class="px-2 py-1 bg-gray-100 rounded text-xs">
                        {cat}
                      </span>
                    ))}
                  </span>
                )}
              </div>

              {post.data.description && (
                <p class="text-gray-700 mb-4">
                  {post.data.description}
                </p>
              )}

              <a
                href={`/blog/${slug}`}
                class="inline-flex items-center text-sm text-blue-600 hover:text-blue-800"
              >
                Read more →
              </a>
            </article>
          );
        })}
      </div>

    </main>
  </body>
</html>
