---
import SidebarNav from '../components/SidebarNav.astro';
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Learn more about Justin Johnson, creative technologist and sound designer" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>About - Justin Johnson</title>
  </head>
  <body class="text-black overflow-x-hidden">
    <!-- Sidebar Navigation -->
    <SidebarNav />

    <!-- Main Content Area -->
    <main class="ml-0 md:ml-[35%] lg:ml-[30%] min-h-screen">
      <div class="p-6 md:p-8 lg:p-12">
        <h1 class="text-3xl md:text-4xl font-light mb-8">About</h1>

        <div class="prose prose-lg max-w-none">
          <p class="text-xl text-gray-600 mb-8">
            I'm a multidisciplinary artist and creative technologist with a focus on interactive
            experiences, sound design, and digital fabrication.
          </p>

          <h2>Background</h2>
          <p>
            My work explores the relationships between technology, sound, and human interaction.
            With a background spanning web development, electronic music production, and physical
            computing, I create projects that bridge the digital and physical worlds.
          </p>

          <h2>Skills & Expertise</h2>
          <ul>
            <li>Creative Technology & Interactive Design</li>
            <li>Sound Design & Electronic Music Production</li>
            <li>Web Development (JavaScript, TypeScript, React, Astro)</li>
            <li>Physical Computing (Arduino, Raspberry Pi)</li>
            <li>Digital Fabrication (3D Printing, Laser Cutting)</li>
            <li>Creative Coding (p5.js, Processing, Max/MSP)</li>
          </ul>

          <h2>Education</h2>
          <p>
            Graduate studies in Interactive Media and Technology, with continued learning
            through hands-on projects and collaboration with other artists and technologists.
          </p>

          <h2>Philosophy</h2>
          <p>
            I believe in the power of technology to enhance human creativity and connection.
            My work often explores themes of play, experimentation, and the unexpected
            beauty that emerges when people interact with responsive systems.
          </p>
        </div>

        <div class="mt-16 pt-8 border-t border-gray-200">
          <h2 class="text-2xl font-light mb-6">Contact</h2>
          <p class="text-lg text-gray-600 mb-8">
            I'm always interested in new projects, collaborations, and conversations
            about technology, art, and sound.
          </p>

          <div class="space-y-6 mb-8">
            <div>
              <h3 class="text-lg font-medium mb-2">Email</h3>
              <a
                href="mailto:hello@jjohnson.art"
                class="text-lg text-blue-600 hover:text-blue-800 transition-colors"
              >
                hello@jjohnson.art
              </a>
            </div>

            <div>
              <h3 class="text-lg font-medium mb-2">Social</h3>
              <ul class="space-y-2">
                <li>
                  <a
                    href="https://github.com/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-blue-600 hover:text-blue-800 transition-colors"
                  >
                    GitHub
                  </a>
                </li>
                <li>
                  <a
                    href="https://linkedin.com/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-blue-600 hover:text-blue-800 transition-colors"
                  >
                    LinkedIn
                  </a>
                </li>
              </ul>
            </div>
          </div>

          <a
            href="mailto:hello@jjohnson.art"
            class="inline-flex items-center gap-2 px-6 py-3 border border-gray-300 hover:border-black transition-colors text-base"
          >
            Contact Me
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
          </a>
        </div>
      </div>
    </main>
  </body>
</html>

<style>
  .prose {
    color: #374151;
    line-height: 1.7;
  }

  .prose h2 {
    color: #111827;
    font-weight: 400;
    font-size: 1.875rem;
    margin-top: 2.5rem;
    margin-bottom: 1.5rem;
  }

  .prose p {
    margin-bottom: 1.5rem;
  }

  .prose ul {
    margin: 1.5rem 0;
    padding-left: 1.5rem;
  }

  .prose li {
    margin-bottom: 0.5rem;
  }
</style>
