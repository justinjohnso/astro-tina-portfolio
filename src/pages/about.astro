---
import SidebarNav from '../components/SidebarNav.astro';
import { ViewTransitions } from 'astro:transitions';
import Page from '../../tina/pages/Page';
import client from '../../tina/__generated__/client';
import '../styles/global.css';

// Get TinaCMS data for visual editing
const tinaProps = await client.queries.pages({ relativePath: 'about.mdx' });
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Learn more about Justin Johnson, creative technologist and sound designer" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>About - Justin Johnson</title>
    <ViewTransitions />
  </head>
  <body class="text-black overflow-x-hidden bg-white">
    <!-- Sidebar Navigation -->
    <SidebarNav />

    <!-- Main Content Area -->
    <main class="ml-0 md:ml-[max(22.8125rem,28%)] lg:ml-[max(22.8125rem,24%)] min-h-screen">
      <!-- CMS-editable content (only renders in TinaCMS iframe via client:tina directive) -->
      <Page {...tinaProps} client:tina />
    </main>
  </body>
</html>
