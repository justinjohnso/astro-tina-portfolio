---
import SidebarNav from '../components/SidebarNav.astro';
import MobileTopNav from '../components/MobileTopNav.astro';
import MainContent from '../layouts/MainContent.astro';
import { ViewTransitions } from 'astro:transitions';
import { getEntry } from 'astro:content';
import Page from '../../tina/pages/Page';
import client from '../../tina/__generated__/client';
import '../styles/global.css';

// Get the about page content from Astro content collections
const aboutPage = await getEntry('pages', 'about');
const { Content: AboutContent } = aboutPage ? await aboutPage.render() : { Content: null };

// Get TinaCMS data for visual editing (this may fail during static build, which is OK)
let tinaProps;
try {
  tinaProps = await client.queries.pages({ relativePath: 'about.mdx' });
} catch {
  tinaProps = null;
}
---

<!DOCTYPE html>
<html lang="en">
  <head>
  <meta charset="UTF-8" />
  <meta name="description" content="Learn more about Justin Johnson, creative technologist and sound designer" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="Permissions-Policy" content="encrypted-media=(*)" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>About - Justin Johnson</title>
    <ViewTransitions />
  </head>
  <body class="text-black overflow-x-hidden bg-white">
    <!-- Mobile Top Navigation -->
    <MobileTopNav />

    <!-- Sidebar Navigation -->
    <SidebarNav />

    <!-- Main Content Area -->
    <MainContent>
      <!-- About page content -->
      {AboutContent && (
        <div class="p-4 md:p-6 lg:p-8 prose prose-lg max-w-none">
          <AboutContent />
        </div>
      )}

      <!-- TinaCMS visual editor (hidden from display, only for editing) -->
      {tinaProps && (
        <div style="display: none;">
          <!-- @ts-ignore: client:tina is an Astro client directive, not a standard prop -->
          <Page {...(tinaProps as any)} client:tina />
        </div>
      )}
    </MainContent>
  </body>
</html>
