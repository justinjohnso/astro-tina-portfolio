---
import SidebarNav from '../components/SidebarNav.astro';
import ProjectGrid from '../components/ProjectGrid.astro';
import { getCollection, getEntry } from 'astro:content';
import { ViewTransitions } from 'astro:transitions';
import Page from '../../tina/pages/Page';
import client from '../../tina/__generated__/client';
import '../styles/global.css';

// Get all projects
const allProjects = await getCollection('projects');

// Get the home page content
const homePage = await getEntry('pages', 'home');

// Get TinaCMS data for visual editing
const tinaProps = await client.queries.pages({ relativePath: 'home.mdx' });

// Get category filter from URL
const categoryFilter = Astro.url.searchParams.get('category');

// Get featured projects list from home page
const featuredProjectSlugs = homePage?.data.featuredProjects || [];

// Filter projects by category if specified
let workingProjects = categoryFilter
  ? allProjects.filter(project =>
      project.data.categories && project.data.categories.includes(categoryFilter)
    )
  : allProjects;

// Separate featured from non-featured (within the filtered set)
const featuredProjects = workingProjects.filter(p =>
  featuredProjectSlugs.includes(p.id) || featuredProjectSlugs.includes(p.slug)
);

const nonFeaturedProjects = workingProjects.filter(p =>
  !featuredProjectSlugs.includes(p.id) && !featuredProjectSlugs.includes(p.slug)
);

// Sort featured projects by the order in featuredProjectSlugs
const orderedFeatured = featuredProjectSlugs
  .map(slug => featuredProjects.find(p => p.id === slug || p.slug === slug))
  .filter(Boolean);

// Sort non-featured by year (newest first)
const orderedNonFeatured = nonFeaturedProjects.sort((a, b) => {
  const yearA = a.data.yearCompleted || 0;
  const yearB = b.data.yearCompleted || 0;
  return yearB - yearA;
});

// Combine: featured first, then non-featured
const orderedProjects = [...orderedFeatured, ...orderedNonFeatured];

// Get category metadata for title
const allCategories = await getCollection('categories');
const categoryData = categoryFilter
  ? allCategories.find(cat => cat.data.categorySlug === categoryFilter)
  : null;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Portfolio of Justin Johnson - Creative Technologist, Sound Designer, and Web Developer" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Justin Johnson - Creative Technologist</title>
    <ViewTransitions />
  </head>
  <body class="text-black overflow-x-hidden bg-white">
    <!-- Sidebar Navigation -->
    <SidebarNav />

    <!-- Main Content Area -->
    <main class="ml-0 md:ml-[max(22.8125rem,28%)] lg:ml-[max(22.8125rem,24%)] min-h-screen">
      <!-- CMS-editable content (only renders in TinaCMS iframe via client:tina directive) -->
      <Page {...tinaProps} client:tina />

      <!-- Category filter header (when filtering) -->
      {categoryFilter && (
        <div class="p-4 md:p-6 lg:p-8 pb-0">
          <h2 class="text-3xl md:text-4xl font-light mb-2">
            {categoryData?.data.title || categoryFilter}
          </h2>
          {categoryData?.data.description && (
            <p class="text-lg text-gray-600 max-w-2xl mb-8">
              {categoryData.data.description}
            </p>
          )}
          <a href="/" class="text-sm text-gray-500 hover:text-black transition-colors">
            ← View all projects
          </a>
        </div>
      )}

      <!-- Project Grid -->
      <div class="p-4 md:p-6 lg:p-8">
        <ProjectGrid projects={orderedProjects} />
      </div>
    </main>
  </body>
</html>
