---
import SidebarNav from '../components/SidebarNav.astro';
import MobileTopNav from '../components/MobileTopNav.astro';
import MainContent from '../layouts/MainContent.astro';
import ProjectGrid from '../components/ProjectGrid.astro';
import { getCollection, getEntry } from 'astro:content';
import { ViewTransitions } from 'astro:transitions';
import Page from '../../tina/pages/Page';
import client from '../../tina/__generated__/client';
import '../styles/global.css';

// Get all projects
const allProjects = await getCollection('projects');

// Get the home page content
const homePage = await getEntry('pages', 'home');
const { Content: HomeContent } = homePage ? await homePage.render() : { Content: null };

// Get TinaCMS data for visual editing (may fail during static build without Tina Cloud)
let tinaProps;
try {
  tinaProps = await client.queries.pages({ relativePath: 'home.mdx' });
} catch {
  tinaProps = null;
}

/**
 * Featured Projects Sorting System
 *
 * Featured status is determined by the `featured: true` field on each project.
 * The homepage featuredProjects list is used only for ordering.
 *
 * Sorting logic:
 * - Featured projects: Projects with `featured: true`, ordered by homepage list then by date
 * - Non-featured projects: Sorted by yearCompleted (newest first)
 */

// Extract featured project order from homepage (for ordering, not for determining featured status)
const featuredProjectOrder = (homePage.data.featuredProjects || []).map((item: unknown, index: number) => {
  // Extract slug from path like "src/content/projects/look-listen.mdx"
  const projectPath = (item as any)?.project as string | undefined;
  const match = projectPath ? projectPath.match(/projects\/(.+)\.mdx$/) : null;
  return { slug: match ? match[1] : null, order: index };
}).filter(item => item.slug !== null);

// Featured projects are determined by the `featured` field on the project itself
const featuredProjects = allProjects
  .filter(p => p.data.featured === true)
  .sort((a, b) => {
    // Sort by homepage order if specified, otherwise by date
    const orderA = featuredProjectOrder.find(item => item.slug === a.slug)?.order ?? 999;
    const orderB = featuredProjectOrder.find(item => item.slug === b.slug)?.order ?? 999;
    if (orderA !== orderB) return orderA - orderB;
    // Fallback to date for featured projects not in the homepage list
    const yearA = a.data.dateCompleted ? new Date(a.data.dateCompleted).getFullYear() : 0;
    const yearB = b.data.dateCompleted ? new Date(b.data.dateCompleted).getFullYear() : 0;
    return yearB - yearA;
  });

const featuredSlugs = new Set(featuredProjects.map(p => p.slug));
const nonFeaturedProjects = allProjects.filter(p => !featuredSlugs.has(p.slug));

// Sort non-featured by year (newest first)
const sortByYear = (a: typeof allProjects[0], b: typeof allProjects[0]) => {
  const yearA = a.data.dateCompleted ? new Date(a.data.dateCompleted).getFullYear() : 0;
  const yearB = b.data.dateCompleted ? new Date(b.data.dateCompleted).getFullYear() : 0;
  return yearB - yearA;
};

nonFeaturedProjects.sort(sortByYear);

// Combine: featured first (in homepage order), then non-featured (by year)
const orderedProjects = [...featuredProjects, ...nonFeaturedProjects];

// Get category metadata for client-side use
const allCategories = await getCollection('categories');
const categoryMetadata = allCategories.map(cat => ({
  slug: cat.data.categorySlug,
  title: cat.data.title,
  description: cat.data.description,
}));
---

<!DOCTYPE html>
<html lang="en">
  <head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="Permissions-Policy" content="encrypted-media=(*)" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/favicon.ico" />
  <title>{homePage?.data.title || 'Justin Johnson – Creative Technologist'}</title>
  <meta name="description" content={homePage?.data.description || "Hi! I'm Justin, a multi-disciplinary technologist with a background in theatre and the heart of a tinkerer. When I'm not talking to computers, I spend my time building interactive auditory worlds, both through theatre and technology."} />

  <!-- OpenGraph -->
  <meta property="og:title" content={homePage?.data.title || 'Justin Johnson – Creative Technologist'} />
  <meta property="og:description" content={homePage?.data.description || "Hi! I'm Justin, a multi-disciplinary technologist with a background in theatre and the heart of a tinkerer. When I'm not talking to computers, I spend my time building interactive auditory worlds, both through theatre and technology."} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content="https://justintime.art/og-image.jpg" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={homePage?.data.title || 'Justin Johnson – Creative Technologist'} />
  <meta name="twitter:description" content={homePage?.data.description || "Hi! I'm Justin, a multi-disciplinary technologist with a background in theatre and the heart of a tinkerer. When I'm not talking to computers, I spend my time building interactive auditory worlds, both through theatre and technology."} />
  <meta name="twitter:image" content="https://justintime.art/og-image.jpg" />

    <ViewTransitions />
  </head>
  <body class="text-black overflow-x-hidden bg-white">
    <!-- Mobile Top Navigation -->
    <MobileTopNav />

    <!-- Sidebar Navigation -->
    <SidebarNav />

    <!-- Main Content Area -->
    <MainContent>
      <!-- Homepage content from CMS -->
      <div id="homepage-content">
        {HomeContent && (
          <div class="p-4 md:p-6 lg:p-8 pb-0 prose prose-lg max-w-none">
            <HomeContent />
          </div>
        )}

        <!-- TinaCMS visual editor (hidden from display, only for editing) -->
        {tinaProps && (
          <div style="display: none;">
            <!-- @ts-ignore: client:tina is an Astro client directive, not a standard prop -->
            <Page {...(tinaProps as any)} client:tina />
          </div>
        )}
      </div>

      <!-- Category filter header (dynamically shown by client script) -->
      <div id="category-header" class="p-4 md:p-6 lg:p-8 pb-0" style="display: none;">
        <h2 id="category-title" class="text-3xl md:text-4xl font-light mb-2"></h2>
        <p id="category-description" class="text-lg text-gray-600 max-w-2xl mb-8"></p>
        <a href="/" class="text-sm text-gray-500 hover:text-black transition-colors">
          ← View all projects
        </a>
      </div>

      <!-- Project Grid (filtering handled client-side) -->
      <div class="p-4 md:p-6 lg:p-8">
        <ProjectGrid projects={orderedProjects} />
      </div>
    </MainContent>

    <script define:vars={{ categoryMetadata, allProjectsData: orderedProjects.map(p => ({
      categories: p.data.categories?.map((cat: any) => {
        // Extract slug from category path (e.g., "src/content/categories/theatre.mdx" -> "theatre")
        const catPath = cat.category || cat;
        return catPath.split('/').pop()?.replace('.mdx', '');
      }) || [],
      featured: featuredProjectSlugs.has(p.slug)
    })) }}>
      function applyFilter() {
        const categorySlug = new URLSearchParams(window.location.search).get('category');
        const categoryHeader = document.getElementById('category-header');
        const homepageContent = document.getElementById('homepage-content');
        const projectItems = document.querySelectorAll('.project-item');

        if (categorySlug) {
          const category = categoryMetadata.find(c => c.slug === categorySlug);
          if (category) {
            document.getElementById('category-title').textContent = category.title;
            const desc = document.getElementById('category-description');
            desc.textContent = category.description || '';
            desc.style.display = category.description ? 'block' : 'none';
            categoryHeader.style.display = 'block';
            homepageContent.style.display = 'none';
          }

          projectItems.forEach((item, index) => {
            const project = allProjectsData[index];
            item.style.display = project?.categories?.includes(categorySlug) ? '' : 'none';
          });
        } else {
          categoryHeader.style.display = 'none';
          homepageContent.style.display = 'block';
          projectItems.forEach(item => item.style.display = '');
        }

        window.relayoutProjectGrid?.();
      }

      applyFilter();
      document.addEventListener('astro:after-swap', applyFilter);
      window.addEventListener('popstate', applyFilter);
    </script>
  </body>
</html>
