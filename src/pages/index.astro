---
import SidebarNav from '../components/SidebarNav.astro';
import ProjectGrid from '../components/ProjectGrid.astro';
import { getCollection, getEntry } from 'astro:content';
import { ViewTransitions } from 'astro:transitions';
import Page from '../../tina/pages/Page';
import client from '../../tina/__generated__/client';
import '../styles/global.css';

// Get all projects
const allProjects = await getCollection('projects');

// Get the home page content
const homePage = await getEntry('pages', 'home');
const { Content: HomeContent } = homePage ? await homePage.render() : { Content: null };

// Get TinaCMS data for visual editing
const tinaProps = await client.queries.pages({ relativePath: 'home.mdx' });

/**
 * Featured Projects Sorting System
 *
 * Featured projects are managed from the homepage frontmatter in TinaCMS.
 * This allows for drag-and-drop ordering and centralized control.
 *
 * Sorting logic:
 * - Featured projects: Sorted by homepage list order (manual curation)
 * - Non-featured projects: Sorted by yearCompleted (newest first)
 */

// Extract featured project slugs and their order from homepage
const featuredProjectOrder = (homePage.data.featuredProjects || []).map((item: unknown, index: number) => {
  // Extract slug from path like "src/content/projects/look-listen.mdx"
  const projectPath = (item as any)?.project as string | undefined;
  const match = projectPath ? projectPath.match(/projects\/(.+)\.mdx$/) : null;
  return { slug: match ? match[1] : null, order: index };
}).filter(item => item.slug !== null);

const featuredProjectSlugs = new Set(featuredProjectOrder.map(item => item.slug));

// Sort projects: featured first (by homepage order), then non-featured (by year)
const featuredProjects = allProjects
  .filter(p => featuredProjectSlugs.has(p.slug))
  .sort((a, b) => {
    // Sort by the order defined in homepage featuredProjects
    const orderA = featuredProjectOrder.find(item => item.slug === a.slug)?.order ?? 999;
    const orderB = featuredProjectOrder.find(item => item.slug === b.slug)?.order ?? 999;
    return orderA - orderB;
  });

const nonFeaturedProjects = allProjects.filter(p => !featuredProjectSlugs.has(p.slug));

// Sort non-featured by year (newest first)
const sortByYear = (a: typeof allProjects[0], b: typeof allProjects[0]) => {
  const yearA = a.data.yearCompleted || 0;
  const yearB = b.data.yearCompleted || 0;
  return yearB - yearA;
};

nonFeaturedProjects.sort(sortByYear);

// Combine: featured first (in homepage order), then non-featured (by year)
const orderedProjects = [...featuredProjects, ...nonFeaturedProjects];

// Get category metadata for client-side use
const allCategories = await getCollection('categories');
const categoryMetadata = allCategories.map(cat => ({
  slug: cat.data.categorySlug,
  title: cat.data.title,
  description: cat.data.description,
}));
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{homePage?.data.title || 'Justin Johnson'}</title>
    {homePage?.data.description && (
      <meta name="description" content={homePage.data.description} />
    )}
    <ViewTransitions />
  </head>
  <body class="text-black overflow-x-hidden bg-white">
    <!-- Sidebar Navigation -->
    <SidebarNav />

    <!-- Main Content Area -->
    <main class="ml-0 md:ml-[max(22.8125rem,28%)] lg:ml-[max(22.8125rem,24%)] min-h-screen">
      <!-- Homepage content from CMS -->
      <div id="homepage-content">
        {HomeContent && (
          <div class="p-4 md:p-6 lg:p-8 pb-0 prose prose-lg max-w-none">
            <HomeContent />
          </div>
        )}

        <!-- TinaCMS visual editor (hidden from display, only for editing) -->
        <div style="display: none;">
          <!-- @ts-ignore: client:tina is an Astro client directive, not a standard prop -->
          <Page {...(tinaProps as any)} client:tina />
        </div>
      </div>

      <!-- Category filter header (dynamically shown by client script) -->
      <div id="category-header" class="p-4 md:p-6 lg:p-8 pb-0" style="display: none;">
        <h2 id="category-title" class="text-3xl md:text-4xl font-light mb-2"></h2>
        <p id="category-description" class="text-lg text-gray-600 max-w-2xl mb-8"></p>
        <a href="/" class="text-sm text-gray-500 hover:text-black transition-colors">
          ← View all projects
        </a>
      </div>

      <!-- Project Grid (filtering handled client-side) -->
      <div class="p-4 md:p-6 lg:p-8">
        <ProjectGrid projects={orderedProjects} />
      </div>
    </main>

    <script define:vars={{ categoryMetadata, allProjectsData: orderedProjects.map(p => ({ 
      categories: p.data.categories?.map(catItem => {
        // Handle both old format (string) and new format (object with category property)
        return typeof catItem === 'string' 
          ? catItem 
          : catItem?.category?.split('/').pop()?.replace('.mdx', '') || '';
      }) || [], 
      featured: featuredProjectSlugs.has(p.slug) 
    })) }}>
      function applyFilter() {
        const categorySlug = new URLSearchParams(window.location.search).get('category');
        const categoryHeader = document.getElementById('category-header');
        const homepageContent = document.getElementById('homepage-content');
        const projectItems = document.querySelectorAll('.project-item');

        if (categorySlug) {
          const category = categoryMetadata.find(c => c.slug === categorySlug);
          if (category) {
            document.getElementById('category-title').textContent = category.title;
            const desc = document.getElementById('category-description');
            desc.textContent = category.description || '';
            desc.style.display = category.description ? 'block' : 'none';
            categoryHeader.style.display = 'block';
            homepageContent.style.display = 'none';
          }

          projectItems.forEach((item, index) => {
            const project = allProjectsData[index];
            item.style.display = project?.categories?.includes(categorySlug) ? '' : 'none';
          });
        } else {
          categoryHeader.style.display = 'none';
          homepageContent.style.display = 'block';
          projectItems.forEach(item => item.style.display = '');
        }

        window.relayoutProjectGrid?.();
      }

      applyFilter();
      document.addEventListener('astro:after-swap', applyFilter);
      window.addEventListener('popstate', applyFilter);
    </script>
  </body>
</html>
