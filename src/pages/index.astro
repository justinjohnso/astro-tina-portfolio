---
import SidebarNav from '../components/SidebarNav.astro';
import ProjectGrid from '../components/ProjectGrid.astro';
import { getCollection } from 'astro:content';
import '../styles/global.css';

// Get all projects and sort them by yearCompleted
const allProjects = await getCollection('projects');

const orderedProjects = [...allProjects].sort((a, b) => {
  const yearA = a.data.yearCompleted || 0;
  const yearB = b.data.yearCompleted || 0;
  return yearB - yearA;
});
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Portfolio of Justin Johnson - Creative Technologist, Sound Designer, and Web Developer" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Justin Johnson - Creative Technologist</title>
  </head>
  <body class="text-black overflow-x-hidden">
    <!-- Sidebar Navigation -->
    <SidebarNav />

    <!-- Main Content Area -->
    <main class="ml-0 md:ml-[35%] lg:ml-[30%] min-h-screen">
      <div class="p-6 md:p-8 lg:p-12">
        <!-- Welcome Section (shown by default) -->
        <section id="welcome-section" class="mb-12">
          <h2 class="text-3xl md:text-4xl font-light mb-6">
            Creative Technologist & Sound Designer
          </h2>
          <p class="text-lg text-gray-600 max-w-2xl mb-8">
            Exploring the intersection of technology, sound, and interactive experiences.
            Select a project from the sidebar to view details, or browse by category.
          </p>
        </section>

        <!-- Project Grid -->
        <section id="projects-section">
          <ProjectGrid projects={orderedProjects} />
        </section>
      </div>
    </main>

    <script>
      // Listen for category changes from sidebar
      window.addEventListener('categoryChange', ((e: CustomEvent) => {
        const { category } = e.detail;
        const projectsSection = document.getElementById('projects-section');
        const welcomeSection = document.getElementById('welcome-section');
        
        if (!projectsSection) return;
        
        // Get all projects
        const allProjectLinks = document.querySelectorAll('.project-link');
        const allProjectSlugs = Array.from(allProjectLinks)
          .filter(link => {
            const linkCategory = link.getAttribute('data-category');
            return category === 'all' || linkCategory === category;
          })
          .map(link => link.getAttribute('data-slug'));
        
        // Filter grid items
        const gridItems = document.querySelectorAll('.project-item');
        gridItems.forEach(item => {
          const href = item.getAttribute('href');
          if (href) {
            const slug = href.replace('/projects/', '');
            if (category === 'all' || allProjectSlugs.includes(slug)) {
              (item as HTMLElement).style.display = '';
            } else {
              (item as HTMLElement).style.display = 'none';
            }
          }
        });
        
        // Show/hide welcome section
        if (welcomeSection) {
          if (category === 'all') {
            welcomeSection.style.display = 'block';
          } else {
            welcomeSection.style.display = 'none';
          }
        }
      }) as EventListener);
    </script>
  </body>
</html>
