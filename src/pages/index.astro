---
import SidebarNav from '../components/SidebarNav.astro';
import ProjectGrid from '../components/ProjectGrid.astro';
import { getCollection, getEntry } from 'astro:content';
import { ViewTransitions } from 'astro:transitions';
import PageComponent from '../../tina/pages/PageComponent';
import client from '../../tina/__generated__/client';
import '../styles/global.css';

// Get all projects
const allProjects = await getCollection('projects');

// Get the home page content
const homePage = await getEntry('pages', 'home');

// Get TinaCMS data for visual editing
async function getTinaProps() {
  const tinaProps = {
    data: {},
    query: '',
    variables: { relativePath: 'home.mdx' },
  };

  try {
    const response = await client.queries.pages({
      relativePath: 'home.mdx',
    });
    tinaProps.data = response.data;
    tinaProps.query = response.query;
    tinaProps.variables = response.variables;
  } catch (error) {
    console.error('Error fetching Tina data:', error);
  }

  return tinaProps;
}

const tinaProps = await getTinaProps();

// Get category filter from URL
const categoryFilter = Astro.url.searchParams.get('category');

// Filter projects by category if specified
let filteredProjects = allProjects;
if (categoryFilter) {
  filteredProjects = allProjects.filter(project =>
    project.data.categories && project.data.categories.includes(categoryFilter)
  );
}

// Sort with featured projects first, then by year
const orderedProjects = [...filteredProjects].sort((a, b) => {
  // Featured projects come first
  const aFeatured = a.data.featured || false;
  const bFeatured = b.data.featured || false;

  if (aFeatured && !bFeatured) return -1;
  if (!aFeatured && bFeatured) return 1;

  // Within same featured status, sort by year (newest first)
  const yearA = a.data.yearCompleted || 0;
  const yearB = b.data.yearCompleted || 0;
  return yearB - yearA;
});

// Get category metadata for title
const allCategories = await getCollection('categories');
const categoryData = categoryFilter
  ? allCategories.find(cat => cat.data.categorySlug === categoryFilter)
  : null;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Portfolio of Justin Johnson - Creative Technologist, Sound Designer, and Web Developer" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Justin Johnson - Creative Technologist</title>
    <ViewTransitions />
  </head>
  <body class="text-black overflow-x-hidden bg-white">
    <!-- Sidebar Navigation -->
    <SidebarNav />

    <!-- Main Content Area -->
    <main class="ml-0 md:ml-[max(22.8125rem,28%)] lg:ml-[max(22.8125rem,24%)] min-h-screen">
      <div class="p-4 md:p-6 lg:p-8">
        <!-- Welcome Section (shown by default) -->
        <div id="welcome-section">
          <!-- TinaCMS Visual Editor Wrapper (only shows in iframe) -->
          <div id="tina-wrapper" style="display: none;">
            <PageComponent {...tinaProps} client:tina />
          </div>

          <!-- Static Content (shows in production) -->
          <section id="static-content" class="mb-12">
            {categoryFilter ? (
              <div>
                <h2 class="text-3xl md:text-4xl font-light mb-2">
                  {categoryData?.data.title || categoryFilter}
                </h2>
                {categoryData?.data.description && (
                  <p class="text-lg text-gray-600 max-w-2xl mb-8">
                    {categoryData.data.description}
                  </p>
                )}
                <a href="/" class="text-sm text-gray-500 hover:text-black transition-colors">
                  ← View all projects
                </a>
              </div>
            ) : (
              <div>
                <h2 class="text-3xl md:text-4xl font-light mb-6">
                  {homePage?.data.title || 'Creative Technologist & Sound Designer'}
                </h2>
                <p class="text-lg text-gray-600 max-w-2xl mb-8">
                  {homePage?.data.description || 'Exploring the intersection of technology, sound, and interactive experiences. Select a project from the sidebar to view details, or browse by category.'}
                </p>
              </div>
            )}
          </section>
        </div>

        <!-- Project Grid -->
        <section id="projects-section">
          <ProjectGrid projects={orderedProjects} />
        </section>
      </div>
    </main>

    <!-- Toggle between TinaCMS and static content based on iframe context -->
    <script>
      const isInIframe = window.self !== window.top;
      const tinaWrapper = document.getElementById('tina-wrapper');
      const staticContent = document.getElementById('static-content');

      if (isInIframe) {
        if (tinaWrapper) tinaWrapper.style.display = 'block';
        if (staticContent) staticContent.style.display = 'none';
      } else {
        if (tinaWrapper) tinaWrapper.style.display = 'none';
        if (staticContent) staticContent.style.display = 'block';
      }
    </script>

    <!-- Client-side filtering script -->
    <script define:vars={{ allProjectsData: allProjects.map(p => ({ slug: p.slug, categories: p.data.categories || [], featured: p.data.featured || false, yearCompleted: p.data.yearCompleted || 0 })) }}>
      function applyFiltering() {
        const urlParams = new URLSearchParams(window.location.search);
        const categoryFilter = urlParams.get('category');

        if (categoryFilter) {
          // Filter project cards by category
          const projectItems = document.querySelectorAll('.project-item');
          projectItems.forEach(item => {
            const projectSlug = item.getAttribute('href')?.split('/').pop();
            const project = allProjectsData.find(p => p.slug === projectSlug);

            if (project && project.categories.includes(categoryFilter)) {
              item.style.display = '';
            } else {
              item.style.display = 'none';
            }
          });
        }
      }

      // Run on initial page load
      document.addEventListener('DOMContentLoaded', applyFiltering);
      
      // Run after view transitions complete
      document.addEventListener('astro:page-load', applyFiltering);
    </script>
  </body>
</html>
