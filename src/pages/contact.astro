---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact - Justin Johnson" description="Get in touch with Justin Johnson">
  <div class="max-w-2xl mx-auto px-4 py-12">
    <h1 class="text-4xl md:text-6xl font-light mb-8">Contact</h1>

    <div class="prose prose-lg max-w-none">
      <p class="text-xl text-gray-600 mb-8">
        I'm always interested in new projects, collaborations, and conversations
        about technology, art, and sound.
      </p>

      <h2>Ways to Connect</h2>

      <div class="space-y-6">
        <div>
          <h3>Email</h3>
          <a
            href="mailto:hello@jjohnson.art"
            class="text-lg text-blue-600 hover:text-blue-800 transition-colors"
          >
            hello@jjohnson.art
          </a>
        </div>

        <div>
          <h3>Social</h3>
          <ul class="space-y-2">
            <li>
              <a
                href="https://github.com/"
                target="_blank"
                rel="noopener noreferrer"
                class="text-blue-600 hover:text-blue-800 transition-colors"
              >
                GitHub
              </a>
            </li>
            <li>
              <a
                href="https://linkedin.com/"
                target="_blank"
                rel="noopener noreferrer"
                class="text-blue-600 hover:text-blue-800 transition-colors"
              >
                LinkedIn
              </a>
            </li>
            <li>
              <a
                href="https://twitter.com/"
                target="_blank"
                rel="noopener noreferrer"
                class="text-blue-600 hover:text-blue-800 transition-colors"
              >
                Twitter
              </a>
            </li>
          </ul>
        </div>
      </div>

      <h2>What I'm Looking For</h2>
      <ul>
        <li>Creative technology collaborations</li>
        <li>Interactive media projects</li>
        <li>Sound design opportunities</li>
        <li>Web development consulting</li>
        <li>Speaking engagements</li>
        <li>Teaching opportunities</li>
      </ul>

      <p>
        Whether you have a specific project in mind or just want to chat about
        creative technology, I'd love to hear from you.
      </p>
    </div>

    <div class="mt-12">
      <a
        href="/"
        class="inline-flex items-center gap-2 text-gray-600 hover:text-black transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 12H5m6-7l-7 7 7 7"></path>
        </svg>
        Back to Projects
      </a>
    </div>
  </div>
</Layout>

<style>
  .prose {
    color: #374151;
    line-height: 1.7;
  }

  .prose h2 {
    color: #111827;
    font-weight: 400;
    font-size: 1.875rem;
    margin-top: 2.5rem;
    margin-bottom: 1.5rem;
  }

  .prose h3 {
    color: #111827;
    font-weight: 500;
    font-size: 1.25rem;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .prose p {
    margin-bottom: 1.5rem;
  }

  .prose ul {
    margin: 1.5rem 0;
    padding-left: 1.5rem;
  }

  .prose li {
    margin-bottom: 0.5rem;
  }
</style>
