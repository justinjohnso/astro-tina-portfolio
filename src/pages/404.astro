---
import Layout from '../layouts/Layout.astro';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>404 - Page Not Found</title>
  </head>
  <body class="text-black bg-white">
    <main class="min-h-screen flex items-center justify-center px-4">
      <div class="max-w-2xl w-full text-center">
        <h1 class="text-9xl font-bold text-gray-200 mb-4">404</h1>
        <h2 class="text-3xl md:text-4xl font-medium mb-4">Page Not Found</h2>
        <p class="text-lg text-gray-600 mb-8">
          The page you're looking for doesn't exist or has been moved.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/"
            class="inline-flex items-center justify-center px-6 py-3 border border-black text-black hover:bg-black hover:text-white transition-colors"
          >
            ← Back to Home
          </a>
          <a
            href="/projects"
            class="inline-flex items-center justify-center px-6 py-3 border border-gray-300 text-gray-700 hover:border-black hover:text-black transition-colors"
          >
            View Projects
          </a>
        </div>
      </div>
    </main>
  </body>
</html>
