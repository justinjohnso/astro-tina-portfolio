    </div>

    <!-- About Link -->
    <div class="mb-8">
      <a href="/about" class="block font-medium text-lg text-black hover:text-gray-600 transition-colors">
        About
      </a>
    </div>

    <!-- Categories (accordion) -->
    <div class="categories-container">
      {categories.map(([categorySlug, projects]) => {
        const categoryData = categoryMetadata.get(categorySlug);
        const displayName = categoryData?.title || categorySlug;

        // Debug specific category
        if (categorySlug === 'physical-computing') {
          console.log('DEBUG - Rendering physical-computing');
          console.log('DEBUG - categoryData:', categoryData);
          console.log('DEBUG - displayName:', displayName);
        }

        return (
          <div class="category-section mb-8">
            <!-- Desktop: simple link, Mobile: accordion button -->
            <a href={`/projects/category/${categorySlug}`} class="category-header hidden md:block font-medium text-lg mb-3 text-black hover:text-gray-600 transition-colors">
              {displayName}
            </a>
            <button
              class="category-toggle md:hidden w-full flex items-center justify-between font-medium text-lg text-black hover:text-gray-600 transition-colors mb-3"
              data-category={categorySlug}
              aria-expanded="false"
            >
              <span>{displayName}</span>
              <svg class="chevron w-5 h-5 transform transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>
            <div class="category-content md:block">
              <ul class="project-list space-y-2">
              {projects.map((project) => {
                const cleanSlug = project.id.replace(/\.mdx$/, '');
                return (
                <li>
                  <a
                    href={`/projects/${cleanSlug}`}
                    class={`project-link block text-base py-1 hover:text-black transition-colors ${
                      currentProjectSlug === cleanSlug ? 'text-black font-medium' : 'text-gray-600'
                    }`}
                    data-slug={cleanSlug}
                    data-year={project.data.dateCompleted ? new Date(project.data.dateCompleted).getFullYear() : ''}
                    data-category={categorySlug}
                  >
                    {project.data.title}
                  </a>
                </li>
                );
              })}
              </ul>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</aside>

<script>
  function initSidebar() {
    const sidebar = document.getElementById('sidebar-nav');
    const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
    if (!sidebar) return;

    // Restore scroll position
    const savedPosition = sessionStorage.getItem('sidebarScrollPosition');
    if (savedPosition) {
      sidebar.scrollTop = parseInt(savedPosition, 10);
    }

    // Save scroll position
    const saveScrollPosition = () => {
      sessionStorage.setItem('sidebarScrollPosition', sidebar.scrollTop.toString());
    };

    sidebar.addEventListener('scroll', saveScrollPosition);
    document.addEventListener('astro:before-preparation', saveScrollPosition);

    // Mobile menu toggle
    if (mobileMenuToggle) {
      mobileMenuToggle.addEventListener('click', () => {
        sidebar.classList.toggle('sidebar-open');
      });

      document.addEventListener('click', (e) => {
        if (!sidebar.contains(e.target as Node) && !mobileMenuToggle.contains(e.target as Node)) {
          sidebar.classList.remove('sidebar-open');
        }
      });
    }

    // Accordion functionality (mobile only)
    const categoryToggles = document.querySelectorAll('.category-toggle');

    const setupAccordion = () => {
      const isMobile = window.innerWidth < 768;

      categoryToggles.forEach(toggle => {
        const content = toggle.nextElementSibling as HTMLElement;

        if (!isMobile) {
          // Desktop: all visible
          toggle.setAttribute('aria-expanded', 'true');
          content?.classList.remove('hidden');
        } else {
          // Mobile: accordion behavior
          toggle.addEventListener('click', () => {
            const icon = toggle.querySelector('.chevron');
            const isExpanded = toggle.getAttribute('aria-expanded') === 'true';

            // Close all others
            categoryToggles.forEach(other => {
              if (other !== toggle) {
                const otherContent = other.nextElementSibling as HTMLElement;
                const otherIcon = other.querySelector('.chevron');
                other.setAttribute('aria-expanded', 'false');
                otherContent?.classList.add('hidden');
                otherIcon?.classList.remove('rotate-180');
              }
            });

            // Toggle current
            toggle.setAttribute('aria-expanded', (!isExpanded).toString());
            content?.classList.toggle('hidden');
            icon?.classList.toggle('rotate-180');
          });
        }
      });
    };

    setupAccordion();
    window.addEventListener('resize', setupAccordion);
  }

  // Run on initial load and after view transitions
  initSidebar();
  document.addEventListener('astro:page-load', initSidebar);
</script>

<style>
  .sidebar {
    /* Position scrollbar on the left */
    direction: rtl;
    overflow-y: auto;
    scrollbar-gutter: stable;
    transition: transform 0.3s ease;
  }

  /* Mobile menu hidden by default */
  @media (max-width: 767px) {
    .sidebar {
      transform: translateX(-100%);
    }

    .sidebar.sidebar-open {
      transform: translateX(0);
    }
  }

  .sidebar > div {
    /* Reset text direction inside */
    direction: ltr;
  }

  /* Show scrollbar only on hover or when scrolling */
  .sidebar::-webkit-scrollbar {
    width: 8px;
  }

  .sidebar::-webkit-scrollbar-track {
    background: transparent;
  }

  .sidebar::-webkit-scrollbar-thumb {
    background: transparent;
    border-radius: 4px;
    transition: background 0.2s ease;
  }

  .sidebar:hover::-webkit-scrollbar-thumb {
    background: #d1d5db;
  }

  .sidebar::-webkit-scrollbar-thumb:hover {
    background: #9ca3af;
  }

  /* Firefox scrollbar styling */
  .sidebar {
    scrollbar-width: thin;
    scrollbar-color: transparent transparent;
  }

  .sidebar:hover {
    scrollbar-color: #d1d5db transparent;
  }
</style>
