---
import { getCollection } from 'astro:content';

// Get all projects
const allProjects = await getCollection('projects');

// Sort projects by yearCompleted (newest first)
const sortedProjects = [...allProjects].sort((a, b) => {
  const yearA = a.data.yearCompleted || 0;
  const yearB = b.data.yearCompleted || 0;
  return yearB - yearA;
});

// Get all category metadata
const allCategories = await getCollection('categories');
const categoryMetadata = new Map(
  allCategories.map(cat => [cat.data.categorySlug, cat.data])
);

// Get unique categories and organize projects by first category
const categoryMap = new Map<string, typeof sortedProjects>();
const projectCategoryMap = new Map<string, string>(); // track which category each project belongs to

sortedProjects.forEach((project) => {
  if (project.data.categories && project.data.categories.length > 0) {
    const firstCategory = project.data.categories[0];

    // Only add project if it hasn't been added yet (first category only)
    if (!projectCategoryMap.has(project.slug)) {
      if (!categoryMap.has(firstCategory)) {
        categoryMap.set(firstCategory, []);
      }
      categoryMap.get(firstCategory)?.push(project);
      projectCategoryMap.set(project.slug, firstCategory);
    }
  }
});

// Convert to array and sort categories alphabetically
const categories = Array.from(categoryMap.entries()).sort((a, b) =>
  a[0].localeCompare(b[0])
);

export interface Props {
  currentProjectSlug?: string;
}

const { currentProjectSlug } = Astro.props;
---

<aside class="sidebar fixed left-0 top-0 bottom-0 w-full md:w-[28%] lg:w-[24%] md:min-w-[22.8125rem] bg-white border-r border-gray-200 overflow-y-auto z-30" id="sidebar-nav">
  <div class="p-6 md:p-8">
    <!-- Hamburger Menu Button (Mobile Only) -->
    <button 
      id="mobile-menu-toggle" 
      class="md:hidden fixed top-4 left-4 z-50 p-2 bg-white border border-gray-200 rounded"
      aria-label="Toggle navigation menu"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>

    <!-- Header -->
    <div class="mb-8 pb-6 border-b border-gray-200">
      <a href="/" class="block group">
        <h1 class="text-2xl md:text-3xl font-light mb-2 group-hover:text-gray-600 transition-colors">
          Justin Johnson
        </h1>
        <p class="text-sm text-gray-500">Creative Technologist</p>
      </a>
    </div>

    <!-- About Link -->
    <div class="mb-8">
      <a href="/about" class="block font-medium text-lg text-black hover:text-gray-600 transition-colors">
        About
      </a>
    </div>

    <!-- Categories (accordion) -->
    <div class="categories-container">
      {categories.map(([categorySlug, projects]) => {
        const categoryData = categoryMetadata.get(categorySlug);
        const displayName = categoryData?.title || categorySlug;

        return (
          <div class="category-section mb-6">
            <button 
              class="category-toggle w-full flex items-center justify-between font-medium text-lg text-black hover:text-gray-600 transition-colors mb-3"
              data-category={categorySlug}
              aria-expanded="false"
            >
              <span>{displayName}</span>
              <svg class="w-5 h-5 transform transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>
            <div class="category-content hidden">
              {categoryData?.description && (
                <p class="text-sm text-gray-500 mb-3 leading-relaxed">
                  {categoryData.description}
                </p>
              )}
              <ul class="project-list space-y-2">
              {projects.map((project) => (
                <li>
                  <a
                    href={`/projects/${project.slug}`}
                    class={`project-link block text-base py-1 hover:text-black transition-colors ${
                      currentProjectSlug === project.slug ? 'text-black font-medium' : 'text-gray-600'
                    }`}
                    data-slug={project.slug}
                    data-year={project.data.yearCompleted}
                    data-category={categorySlug}
                  >
                    {project.data.title}
                  </a>
                </li>
              ))}
              </ul>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</aside>

<script>
  // No toggle logic needed - all categories are always expanded
</script>

<script is:inline>
  // Restore scroll position immediately to prevent jump
  (function() {
    const savedPosition = sessionStorage.getItem('sidebarScrollPosition');
    if (savedPosition) {
      // Use requestAnimationFrame to ensure DOM is ready but before paint
      requestAnimationFrame(() => {
        const sidebar = document.getElementById('sidebar-nav');
        if (sidebar) {
          sidebar.scrollTop = parseInt(savedPosition, 10);
        }
      });
    }
  })();
</script>

<script>
  // Save scroll position on navigation
  document.addEventListener('DOMContentLoaded', () => {
    const sidebar = document.getElementById('sidebar-nav');
    if (sidebar) {
      // Save scroll position before navigation
      const saveScrollPosition = () => {
        sessionStorage.setItem('sidebarScrollPosition', sidebar.scrollTop.toString());
      };

      // Save on scroll
      sidebar.addEventListener('scroll', saveScrollPosition);

      // Save before navigation
      window.addEventListener('beforeunload', saveScrollPosition);

      // Save on link clicks
      sidebar.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', saveScrollPosition);
      });
    }

    // Mobile menu toggle
    const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
    if (mobileMenuToggle && sidebar) {
      mobileMenuToggle.addEventListener('click', () => {
        sidebar.classList.toggle('sidebar-open');
      });

      // Close menu when clicking outside
      document.addEventListener('click', (e) => {
        if (!sidebar.contains(e.target as Node) && !mobileMenuToggle.contains(e.target as Node)) {
          sidebar.classList.remove('sidebar-open');
        }
      });
    }

    // Accordion functionality
    const categoryToggles = document.querySelectorAll('.category-toggle');
    categoryToggles.forEach(toggle => {
      toggle.addEventListener('click', () => {
        const content = toggle.nextElementSibling as HTMLElement;
        const icon = toggle.querySelector('svg');
        const isExpanded = toggle.getAttribute('aria-expanded') === 'true';

        // Close all other categories
        categoryToggles.forEach(otherToggle => {
          if (otherToggle !== toggle) {
            const otherContent = otherToggle.nextElementSibling as HTMLElement;
            const otherIcon = otherToggle.querySelector('svg');
            otherToggle.setAttribute('aria-expanded', 'false');
            otherContent?.classList.add('hidden');
            otherIcon?.classList.remove('rotate-180');
          }
        });

        // Toggle current category
        if (isExpanded) {
          toggle.setAttribute('aria-expanded', 'false');
          content?.classList.add('hidden');
          icon?.classList.remove('rotate-180');
        } else {
          toggle.setAttribute('aria-expanded', 'true');
          content?.classList.remove('hidden');
          icon?.classList.add('rotate-180');
        }
      });
    });
  });
</script>

<style>
  .sidebar {
    /* Position scrollbar on the left */
    direction: rtl;
    overflow-y: auto;
    scrollbar-gutter: stable;
    transition: transform 0.3s ease;
  }

  /* Mobile menu hidden by default */
  @media (max-width: 767px) {
    .sidebar {
      transform: translateX(-100%);
    }

    .sidebar.sidebar-open {
      transform: translateX(0);
    }
  }

  .sidebar > div {
    /* Reset text direction inside */
    direction: ltr;
  }

  /* Show scrollbar only on hover or when scrolling */
  .sidebar::-webkit-scrollbar {
    width: 8px;
  }

  .sidebar::-webkit-scrollbar-track {
    background: transparent;
  }

  .sidebar::-webkit-scrollbar-thumb {
    background: transparent;
    border-radius: 4px;
    transition: background 0.2s ease;
  }

  .sidebar:hover::-webkit-scrollbar-thumb {
    background: #d1d5db;
  }

  .sidebar::-webkit-scrollbar-thumb:hover {
    background: #9ca3af;
  }

  /* Firefox scrollbar styling */
  .sidebar {
    scrollbar-width: thin;
    scrollbar-color: transparent transparent;
  }

  .sidebar:hover {
    scrollbar-color: #d1d5db transparent;
  }
</style>
