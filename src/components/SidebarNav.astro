---
import { getCollection } from 'astro:content';

// Get all projects and sort by date (newest first)
const allProjects = await getCollection('projects');
const sortedProjects = allProjects.sort((a, b) => {
  const yearA = a.data.dateCompleted ? new Date(a.data.dateCompleted).getFullYear() : 0;
  const yearB = b.data.dateCompleted ? new Date(b.data.dateCompleted).getFullYear() : 0;
  return yearB - yearA;
});

// Get all category metadata - use categorySlug as the key
const allCategories = await getCollection('categories');
const categoryMetadata = new Map(
  allCategories.map(cat => [cat.data.categorySlug, cat.data])
);

// Get category order from home page
const homePages = await getCollection('pages', ({ id }) => id === 'home.mdx');
const homePage = homePages[0];
const categoryOrderConfig = homePage?.data?.categoryOrder || [];

// Debug: log category metadata
console.log('DEBUG - categoryMetadata keys:', Array.from(categoryMetadata.keys()));
console.log('DEBUG - physical-computing data:', categoryMetadata.get('physical-computing'));

// Also create a map from filename to categorySlug for backward compatibility
const filenameToCategorySlug = new Map<string, string>(
  allCategories.map(cat => [cat.id, cat.data.categorySlug])
);

// Get unique categories and organize projects by first category
const categoryMap = new Map<string, typeof sortedProjects>();
const projectCategoryMap = new Map<string, string>(); // track which category each project belongs to
const uncategorizedProjects: typeof sortedProjects = [];

sortedProjects.forEach((project) => {
  if (project.data.categories && project.data.categories.length > 0) {
    let firstCategory = project.data.categories[0];
    let categorySlug: string | undefined;

    // Handle both string format and object format
    if (typeof firstCategory === 'string') {
      categorySlug = firstCategory;
    } else if (firstCategory && typeof firstCategory === 'object' && 'category' in firstCategory) {
      // Extract slug from reference path like "src/content/categories/sound-design.mdx"
      const categoryPath = firstCategory.category as string;
      const match = categoryPath.match(/([^/]+)\.mdx?$/);
      if (match) {
        categorySlug = match[1];
      }
    }

    if (categorySlug) {
      // Convert filename to categorySlug if needed (check if it's actually a filename)
      const mappedSlug = filenameToCategorySlug.get(categorySlug) || categorySlug;

      // Only add project if it hasn't been added yet (first category only)
      if (!projectCategoryMap.has(project.id)) {
        if (!categoryMap.has(mappedSlug)) {
          categoryMap.set(mappedSlug, []);
        }
        categoryMap.get(mappedSlug)?.push(project);
        projectCategoryMap.set(project.id, mappedSlug);
      }
    } else {
      // Category array exists but first item is not a valid string
      uncategorizedProjects.push(project);
    }
  } else {
    // No categories at all
    uncategorizedProjects.push(project);
  }
});

// Add uncategorized projects to a special category if any exist
if (uncategorizedProjects.length > 0) {
  categoryMap.set('uncategorized', uncategorizedProjects);
}

// Sort categories based on categoryOrder from home page
const categoryEntries = Array.from(categoryMap.entries());
const categories = categoryEntries.sort((a, b) => {
  const categorySlugA = String(a[0]);
  const categorySlugB = String(b[0]);
  
  // Extract categorySlug from categoryOrder config
  const getOrderIndex = (slug: string) => {
    const index = categoryOrderConfig.findIndex((item: any) => {
      if (item?.category) {
        const itemSlug = item.category.split('/').pop()?.replace('.mdx', '');
        return itemSlug === slug;
      }
      return false;
    });
    return index === -1 ? 999 : index; // Put unconfigured categories at the end
  };
  
  const indexA = getOrderIndex(categorySlugA);
  const indexB = getOrderIndex(categorySlugB);
  
  if (indexA !== indexB) {
    return indexA - indexB;
  }
  
  // Fall back to alphabetical for categories not in the order config
  return categorySlugA.localeCompare(categorySlugB);
});

export interface Props {
  currentProjectSlug?: string;
}

const { currentProjectSlug } = Astro.props;
---

