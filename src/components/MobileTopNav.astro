---
// Mobile top navigation bar with hamburger menu and home link
---

<!-- Backdrop overlay for mobile menu -->
<div id="mobile-backdrop" class="fixed inset-0 bg-black/50 z-30 hidden md:hidden transition-opacity duration-300"></div>

<nav class="md:hidden fixed top-0 left-0 right-0 bg-white border-b border-gray-200 z-[60] h-16">
  <div class="flex items-center justify-between h-full px-4">
    <!-- Home Link -->
    <a href="/" class="text-lg font-light hover:text-gray-600 transition-colors">
      Justin Johnson
    </a>

    <!-- Hamburger Menu Button -->
    <button
      id="mobile-menu-toggle"
      class="p-2 hover:bg-gray-100 transition-colors rounded"
      aria-label="Toggle navigation menu"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path
          class="hamburger-icon"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"
        ></path>
        <path
          class="close-icon hidden"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"
        ></path>
      </svg>
    </button>
  </div>
</nav>

<script>
  function initMobileNav() {
    const toggle = document.getElementById('mobile-menu-toggle');
    const sidebar = document.getElementById('sidebar-nav');
    const backdrop = document.getElementById('mobile-backdrop');
    
    if (!toggle || !sidebar || !backdrop) {
      console.error('Mobile nav elements not found:', { toggle, sidebar, backdrop });
      return;
    }

    const hamburgerIcon = toggle.querySelector('.hamburger-icon');
    const closeIcon = toggle.querySelector('.close-icon');

    if (!hamburgerIcon || !closeIcon) {
      console.error('Icon elements not found');
      return;
    }

    // Remove any existing listeners by cloning and replacing the button
    const newToggle = toggle.cloneNode(true) as HTMLElement;
    toggle.parentNode?.replaceChild(newToggle, toggle);
    
    // Re-query the icons after cloning
    const newHamburgerIcon = newToggle.querySelector('.hamburger-icon');
    const newCloseIcon = newToggle.querySelector('.close-icon');

    const closeSidebar = () => {
      sidebar.classList.add('-translate-x-full');
      sidebar.classList.remove('translate-x-0', 'shadow-2xl');
      sidebar.style.transform = '';
      backdrop.classList.add('hidden');
      newHamburgerIcon?.classList.remove('hidden');
      newCloseIcon?.classList.add('hidden');
      document.body.style.overflow = '';
    };

    const openSidebar = () => {
      sidebar.classList.remove('-translate-x-full');
      sidebar.classList.add('translate-x-0', 'shadow-2xl');
      sidebar.style.transform = 'translateX(0)';
      backdrop.classList.remove('hidden');
      newHamburgerIcon?.classList.add('hidden');
      newCloseIcon?.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    };

    newToggle.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      
      const isOpen = !sidebar.classList.contains('-translate-x-full');

      if (isOpen) {
        closeSidebar();
      } else {
        openSidebar();
      }
    });

    // Close sidebar when clicking backdrop
    backdrop.addEventListener('click', () => {
      closeSidebar();
    });

    // Close sidebar when clicking links inside (for navigation)
    sidebar.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.tagName === 'A' && window.innerWidth < 768) {
        closeSidebar();
      }
    });
  }

  document.addEventListener('DOMContentLoaded', initMobileNav);
  document.addEventListener('astro:page-load', initMobileNav);
</script>
