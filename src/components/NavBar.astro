---
// No props needed for the static navbar in Astro
---

<script>
  // Client-side script for scroll behavior and active states
  document.addEventListener('DOMContentLoaded', () => {
    const header = document.querySelector('header');
    const navLinks = document.querySelectorAll('nav a');
    const currentPath = window.location.pathname;

    // Handle scroll effect
    const handleScroll = () => {
      const isScrolled = window.scrollY > 10;
      if (header) {
        if (isScrolled) {
          header.classList.add('bg-white/95', 'shadow-sm', 'backdrop-blur-sm');
          header.classList.remove('bg-transparent');
        } else {
          header.classList.remove('bg-white/95', 'shadow-sm', 'backdrop-blur-sm');
          header.classList.add('bg-transparent');
        }
      }
    };

    // Set active nav item
    navLinks.forEach(link => {
      if (link.getAttribute('href') === currentPath) {
        link.classList.add('active-nav-item');
      }
    });

    window.addEventListener('scroll', handleScroll);
  });
</script>

<style>
  .active-nav-item {
    @apply text-black relative;
  }

  .active-nav-item::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 100%;
    height: 1px;
    background-color: black;
  }

  .nav-underline:hover::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 100%;
    height: 1px;
    background-color: black;
    transition: width 0.2s ease;
  }
</style>

<header class="fixed top-0 left-0 right-0 z-40 py-4 transition-all duration-300 bg-transparent">
  <div class="container mx-auto px-4 flex justify-between items-center">
    <a href="/" class="text-xl font-light relative nav-underline">
      Justin Johnson
    </a>

    <nav>
      <ul class="flex space-x-6">
        <li>
          <a
            href="/about"
            class="relative font-light text-gray-600 hover:text-black nav-underline"
          >
            About
          </a>
        </li>
        <li>
          <a
            href="/contact"
            class="relative font-light text-gray-600 hover:text-black nav-underline"
          >
            Contact
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>
