---
import type { CollectionEntry } from 'astro:content';

export interface Props {
  projects: CollectionEntry<'projects'>[];
}

const { projects } = Astro.props;
---

<div class="project-grid" id="project-grid">
  {projects.map((project, index) => (
    <a href={`/projects/${project.slug}`} class="project-item group relative overflow-hidden" data-index={index}>
      <div class="project-image-container h-full">
        <img
          src={project.data.image || '/placeholder.jpg'}
          alt={project.data.title}
          class="project-image object-cover w-full h-full transition-transform duration-700 group-hover:scale-105"
        />
        <div class="project-overlay absolute inset-0 bg-white/30 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        <div class="project-content absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
          <div class="bg-black/60 p-3 max-w-[80%] text-center">
            <h3 class="text-white text-base sm:text-lg font-normal">
              {project.data.title}
            </h3>
            {project.data.dateCompleted && (
              <span class="text-white text-sm">
                {project.data.dateCompleted.getFullYear()}
              </span>
            )}
          </div>
        </div>
      </div>
    </a>
  ))}
</div>

<script>
  function initProjectGrid() {
    const grid = document.getElementById('project-grid');
    const allItems = Array.from(document.querySelectorAll('.project-item')) as HTMLElement[];
    if (!grid || !allItems.length) return;

    const getColumns = () => {
      if (window.innerWidth < 640) return 1;
      if (window.innerWidth < 768) return 2;
      return 3;
    };

    const patterns = {
      1: ['small', 'tall'],
      2: ['large', 'small', 'wide', 'tall', 'small', 'wide'],
      3: ['large', 'small', 'wide', 'small', 'tall', 'small', 'wide', 'tall', 'small']
    } as const;

    // Helper to calculate cells used by a size
    const getSizeCells = (size: string, columns: number): number => {
      if (columns === 1) return 1;
      if (size === 'large') return 2; // In 2+ column layouts, large takes 2 columns
      if (size === 'wide' || size === 'tall') return 1; // Each takes 1 column (tall spans 2 rows)
      return 1; // small
    };

    const layoutGrid = () => {
      const columns = getColumns();
      const visibleItems = allItems.filter(item => item.style.display !== 'none');

      // Get project data with importance/featured status
      const projectsWithImportance = visibleItems.map((item, index) => {
        const projectData = (window as any).allProjectsData?.[parseInt(item.getAttribute('data-index') || '0')];
        return {
          item,
          index,
          featured: projectData?.featured || false,
          importance: projectData?.importance || 0
        };
      });

      const totalItems = projectsWithImportance.length;
      if (totalItems === 0) return;

      // PASS 1: Create Size Distribution
      // Simple percentage-based distribution - CSS Grid dense packing handles the rest
      const targetCounts = {
        large: Math.floor(totalItems * 0.15), // 15%
        wide: Math.floor(totalItems * 0.23),  // 23%
        tall: Math.floor(totalItems * 0.25),  // 25%
        small: 0 // ~37% (calculated)
      };

      targetCounts.small = totalItems - (targetCounts.large + targetCounts.wide + targetCounts.tall);

      // Safety check
      if (targetCounts.small < 0) targetCounts.small = 0;

      // Create size array
      const gridSizes: string[] = [];
      for (let i = 0; i < targetCounts.large; i++) gridSizes.push('large');
      for (let i = 0; i < targetCounts.wide; i++) gridSizes.push('wide');
      for (let i = 0; i < targetCounts.tall; i++) gridSizes.push('tall');
      for (let i = 0; i < targetCounts.small; i++) gridSizes.push('small');

      // PASS 2: Shuffle for Visual Variety
      // Simple Fisher-Yates shuffle - CSS Grid dense packing handles the layout
      const shuffledGrid = [...gridSizes];
      for (let i = shuffledGrid.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [shuffledGrid[i], shuffledGrid[j]] = [shuffledGrid[j], shuffledGrid[i]];
      }

      // PASS 3: Assign Sizes to Projects with Importance Distribution
      // Sort projects by importance
      const importanceOrder = projectsWithImportance
        .map((p, idx) => ({ ...p, originalIndex: idx }))
        .sort((a, b) => {
          if (a.featured !== b.featured) return b.featured ? 1 : -1;
          return b.importance - a.importance;
        });

      // Interleaved distribution pattern: large, small, tall, wide, small, etc.
      const patternUnit = ['large', 'small', 'tall', 'wide', 'small', 'large', 'small', 'tall', 'wide', 'small'];
      const distributionPattern: string[] = [];
      while (distributionPattern.length < totalItems) {
        distributionPattern.push(...patternUnit);
      }

      // Group shuffled positions by size
      const positionsBySize: { [key: string]: number[] } = { large: [], tall: [], wide: [], small: [] };
      shuffledGrid.forEach((size, index) => positionsBySize[size].push(index));

      // Track usage
      const sizeIndices = { large: 0, tall: 0, wide: 0, small: 0 };
      const finalSizesForProjects: string[] = new Array(totalItems);

      // Assign using pattern with fallback
      for (let i = 0; i < totalItems; i++) {
        const project = importanceOrder[i];
        let selectedSize = distributionPattern[i];

        // Find available size
        const sizeOptions = ['large', 'tall', 'wide', 'small'];
        if (sizeIndices[selectedSize as keyof typeof sizeIndices] >= positionsBySize[selectedSize].length) {
          selectedSize = sizeOptions.find(s => sizeIndices[s as keyof typeof sizeIndices] < positionsBySize[s].length) || 'small';
        }

        const positionIndex = sizeIndices[selectedSize as keyof typeof sizeIndices]++;
        const gridPosition = positionsBySize[selectedSize][positionIndex];
        finalSizesForProjects[project.originalIndex] = shuffledGrid[gridPosition];
      }

      // Apply initial sizes to DOM
      projectsWithImportance.forEach(({ item }, idx) => {
        const size = finalSizesForProjects[idx];
        const isWide = size === 'wide' || size === 'large';
        const isTall = size === 'tall' || size === 'large';
        item.style.gridColumnEnd = isWide ? 'span 2' : 'span 1';
        item.style.gridRowEnd = isTall ? 'span 2' : 'span 1';
      });

      // Debug output
      const sizeCounts = { small: 0, wide: 0, tall: 0, large: 0 };
      finalSizesForProjects.forEach(size => sizeCounts[size as keyof typeof sizeCounts]++);
      console.log(`📊 Grid Layout (${columns} cols, ${totalItems} items):`, sizeCounts);

      // PASS 4: Correction Pass - Analyze Actual Rendered Grid
      requestAnimationFrame(() => {
        // Get actual rendered positions
        const itemsWithPositions = projectsWithImportance.map(({ item }, idx) => {
          const rect = item.getBoundingClientRect();
          const isTall = finalSizesForProjects[idx] === 'tall' || finalSizesForProjects[idx] === 'large';
          return {
            idx,
            item,
            size: finalSizesForProjects[idx],
            y: rect.top,
            x: rect.left,
            height: rect.height,
            spansTwoRows: isTall
          };
        });

        // Sort by Y position to identify unique row positions
        itemsWithPositions.sort((a, b) => a.y - b.y);

        // Find unique row Y positions
        const uniqueRowYs: number[] = [];
        const rowThreshold = 10;
        itemsWithPositions.forEach(item => {
          if (!uniqueRowYs.some(y => Math.abs(y - item.y) <= rowThreshold)) {
            uniqueRowYs.push(item.y);
          }
        });

        console.log(`🔍 Analyzed ${uniqueRowYs.length} unique row positions`);

        // For each row, count columns occupied (only count items that START in this row)
        const rowAnalysis = uniqueRowYs.map((rowY, rowIdx) => {
          const itemsInRow = itemsWithPositions.filter(item =>
            Math.abs(item.y - rowY) <= rowThreshold
          );

          // Sort by X position
          itemsInRow.sort((a, b) => a.x - b.x);

          // Count columns (wide/large = 2 cols, small/tall = 1 col)
          let colsOccupied = 0;
          itemsInRow.forEach(item => {
            const cols = (item.size === 'wide' || item.size === 'large') ? 2 : 1;
            colsOccupied += cols;
          });

          return { rowIdx, rowY, itemsInRow, colsOccupied, isComplete: colsOccupied >= columns };
        });

        // Check last TWO rows for incompleteness
        const lastRow = rowAnalysis[rowAnalysis.length - 1];
        const secondToLastRow = rowAnalysis[rowAnalysis.length - 2];
        const lastRowIncomplete = lastRow && !lastRow.isComplete;

        if (secondToLastRow) {
          console.log(`   Second-to-last row (${secondToLastRow.rowIdx}): ${secondToLastRow.colsOccupied}/${columns} cols`);
        }
        console.log(`   Last row (${lastRow.rowIdx}): ${lastRow.colsOccupied}/${columns} cols ${lastRowIncomplete ? '(incomplete - will fix)' : '(complete)'}`);

        if (lastRowIncomplete) {
          console.log(`🔧 Correction: Last row needs fixing`);

          // Collect downsize candidates from BOTH last two rows
          const downsizeCandidates: { idx: number; size: string; rowIdx: number }[] = [];

          // Add candidates from last row
          lastRow.itemsInRow.forEach(item => {
            if (item.size === 'wide' || item.size === 'large') {
              downsizeCandidates.push({ idx: item.idx, size: item.size, rowIdx: lastRow.rowIdx });
            }
          });

          // Add candidates from second-to-last row
          if (secondToLastRow) {
            secondToLastRow.itemsInRow.forEach(item => {
              if (item.size === 'wide' || item.size === 'large') {
                downsizeCandidates.push({ idx: item.idx, size: item.size, rowIdx: secondToLastRow.rowIdx });
              }
            });
          }

          console.log(`   Found ${downsizeCandidates.length} downsize candidates in last 2 rows`);

          if (downsizeCandidates.length > 0) {
            const changes: string[] = [];

            // Downsize ALL wide/large items in last 2 rows
            // (Being conservative since we can't predict CSS Grid repacking)
            downsizeCandidates.forEach(candidate => {
              const oldSize = finalSizesForProjects[candidate.idx];
              finalSizesForProjects[candidate.idx] = 'small';
              projectsWithImportance[candidate.idx].item.style.gridColumnEnd = 'span 1';
              projectsWithImportance[candidate.idx].item.style.gridRowEnd = 'span 1';
              changes.push(`[${candidate.idx}]: ${oldSize}→small (row ${candidate.rowIdx})`);
            });

            console.log(`✓ Downsized all ${changes.length} wide/large item(s) in last 2 rows:`, changes);
          } else {
            console.log(`⚠️  No downsize candidates found in last 2 rows`);
          }
        } else {
          console.log(`✓ Last row is complete!`);
        }
      });
    };

    layoutGrid();
    window.addEventListener('resize', layoutGrid);
    (window as any).relayoutProjectGrid = layoutGrid;
  }

  document.addEventListener('DOMContentLoaded', initProjectGrid);
  document.addEventListener('astro:page-load', initProjectGrid);
</script>

<style>
  .project-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    grid-auto-rows: 250px;
    gap: 0.5rem;
    grid-auto-flow: dense;
  }

  .project-item {
    display: block;
    height: 100%;
  }

  .project-image-container {
    position: relative;
    height: 100%;
    overflow: hidden;
  }

  @media (max-width: 640px) {
    .project-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 641px) and (max-width: 768px) {
    .project-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
