---
import type { CollectionEntry } from 'astro:content';

export interface Props {
  projects: CollectionEntry<'projects'>[];
}

const { projects } = Astro.props;
---

<div class="project-grid" id="project-grid">
  {projects.map((project, index) => {
    const slug = project.id.replace(/\.mdx$/, '');
    const year = project.data.dateCompleted ? new Date(project.data.dateCompleted).getFullYear() : null;
    
    return (
      <a href={`/projects/${slug}`} class="project-item group relative overflow-hidden" data-index={index}>
        <div class="project-image-container h-full">
          <img
            src={project.data.image || '/placeholder.jpg'}
            alt={project.data.title}
            class="project-image object-cover w-full h-full transition-transform duration-700 group-hover:scale-105"
          />
          <div class="project-overlay absolute inset-0 bg-white/30 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          <div class="project-content absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <div class="bg-black/60 p-3 max-w-[80%] text-center">
              <h3 class="text-white text-base sm:text-lg font-normal">
                {project.data.title}
              </h3>
              {year && (
                <span class="text-white text-sm">
                  {year}
                </span>
              )}
            </div>
          </div>
        </div>
      </a>
    );
  })}
</div>

<script>
  function initProjectGrid() {
    const grid = document.getElementById('project-grid');
    const allItems = Array.from(document.querySelectorAll('.project-item')) as HTMLElement[];
    if (!grid || !allItems.length) return;

    const getColumns = () => {
      if (window.innerWidth < 640) return 1;
      if (window.innerWidth < 1024) return 2;
      return 3;
    };

    /**
     * Main layout function that implements a 4-pass grid sizing system:
     * 1. Size Distribution: Allocate percentages of each cell size
     * 2. Shuffle: Randomize for visual variety
     * 3. Priority Assignment: Featured projects get first pick of larger cells
     * 4. Correction Pass: Fix incomplete last rows to prevent gaps
     */
    const layoutGrid = () => {
      const columns = getColumns();
      const visibleItems = allItems.filter(item => item.style.display !== 'none');

      // Attach project metadata (featured status) to each grid item
      const projectsWithImportance = visibleItems.map((item) => {
        const dataIndex = parseInt(item.getAttribute('data-index') || '0');
        const maybeAllProjects = (window as unknown) as { allProjectsData?: Array<{ featured?: boolean; importance?: number }> };
        const projectData = maybeAllProjects.allProjectsData?.[dataIndex];
        return {
          item,
          featured: projectData?.featured || false,
          importance: projectData?.importance || 0
        };
      });

      const totalItems = projectsWithImportance.length;
      if (totalItems === 0) return;

      // Pass 1: Create size distribution (15% large, 23% wide, 25% tall, 37% small)
      const counts = {
        large: Math.floor(totalItems * 0.15),
        wide: Math.floor(totalItems * 0.23),
        tall: Math.floor(totalItems * 0.25),
        small: 0
      };
      counts.small = totalItems - (counts.large + counts.wide + counts.tall);

      const sizes: string[] = [];
      for (let i = 0; i < counts.large; i++) sizes.push('large');
      for (let i = 0; i < counts.wide; i++) sizes.push('wide');
      for (let i = 0; i < counts.tall; i++) sizes.push('tall');
      for (let i = 0; i < counts.small; i++) sizes.push('small');

      // Pass 2: Shuffle for visual variety
      for (let i = sizes.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [sizes[i], sizes[j]] = [sizes[j], sizes[i]];
      }

      // Pass 3: Assign sizes prioritizing featured projects for larger cells
      // Featured projects get first pick from large → tall → wide → small
      // Non-featured projects get remaining sizes with an interleaved pattern
      const featuredProjects = projectsWithImportance
        .map((p, idx) => ({ ...p, originalIndex: idx }))
        .filter(p => p.featured);

      const nonFeaturedProjects = projectsWithImportance
        .map((p, idx) => ({ ...p, originalIndex: idx }))
        .filter(p => !p.featured);

      // Group available positions by size
      const positionsBySize: { [key: string]: number[] } = { large: [], tall: [], wide: [], small: [] };
      sizes.forEach((size, i) => positionsBySize[size].push(i));

      const finalSizes: string[] = new Array(totalItems);

      // Priority order for sizes (featured projects get first pick)
      const sizeIndices = { large: 0, tall: 0, wide: 0, small: 0 };
      const sizePriority = ['large', 'tall', 'wide', 'small'];

      // Assign featured projects first - they get priority on larger sizes
      featuredProjects.forEach(project => {
        let assignedSize = null;

        // Try to assign in priority order (large -> tall -> wide -> small)
        for (const size of sizePriority) {
          if (sizeIndices[size as keyof typeof sizeIndices] < positionsBySize[size].length) {
            const posIndex = sizeIndices[size as keyof typeof sizeIndices]++;
            finalSizes[project.originalIndex] = sizes[positionsBySize[size][posIndex]];
            assignedSize = size;
            break;
          }
        }
      });

      // Assign non-featured projects - they get remaining sizes with interleaved pattern
      const pattern = ['large', 'small', 'tall', 'wide', 'small', 'large', 'small', 'tall', 'wide', 'small'];
      let patternIndex = 0;

      nonFeaturedProjects.forEach(project => {
        let selectedSize = pattern[patternIndex % pattern.length];
        patternIndex++;

        // Find available size
        if (sizeIndices[selectedSize as keyof typeof sizeIndices] >= positionsBySize[selectedSize].length) {
          selectedSize = sizePriority.find(s =>
            sizeIndices[s as keyof typeof sizeIndices] < positionsBySize[s].length
          ) || 'small';
        }

        const posIndex = sizeIndices[selectedSize as keyof typeof sizeIndices]++;
        finalSizes[project.originalIndex] = sizes[positionsBySize[selectedSize][posIndex]];
      });      // Apply sizes to DOM elements
      projectsWithImportance.forEach(({ item }, idx) => {
        const size = finalSizes[idx];
        item.style.gridColumnEnd = (size === 'wide' || size === 'large') ? 'span 2' : 'span 1';
        item.style.gridRowEnd = (size === 'tall' || size === 'large') ? 'span 2' : 'span 1';
      });

      // Pass 4: Fix incomplete last row by downsizing wide/large cells
      // This prevents gaps in the grid when the last row doesn't fill completely
      requestAnimationFrame(() => {
        const itemsWithPos = projectsWithImportance.map(({ item }, idx) => ({
          idx,
          item,
          size: finalSizes[idx],
          y: item.getBoundingClientRect().top,
          x: item.getBoundingClientRect().left
        }));

        itemsWithPos.sort((a, b) => a.y - b.y);

        const uniqueYs: number[] = [];
        itemsWithPos.forEach(item => {
          if (!uniqueYs.some(y => Math.abs(y - item.y) <= 10)) uniqueYs.push(item.y);
        });

        const rows = uniqueYs.map(y => {
          const items = itemsWithPos.filter(item => Math.abs(item.y - y) <= 10);
          items.sort((a, b) => a.x - b.x);
          const cols = items.reduce((sum, item) =>
            sum + ((item.size === 'wide' || item.size === 'large') ? 2 : 1), 0
          );
          return { items, cols, complete: cols >= columns };
        });

        const lastRow = rows[rows.length - 1];
        if (lastRow && !lastRow.complete) {
          const candidates: typeof itemsWithPos = [];
          [rows[rows.length - 1], rows[rows.length - 2]].forEach(row => {
            if (row) {
              candidates.push(...row.items.filter(item =>
                item.size === 'wide' || item.size === 'large'
              ));
            }
          });

          candidates.forEach(({ idx, item }) => {
            finalSizes[idx] = 'small';
            item.style.gridColumnEnd = 'span 1';
            item.style.gridRowEnd = 'span 1';
          });
        }
      });
    };

    layoutGrid();
    window.addEventListener('resize', layoutGrid);
    (window as any).relayoutProjectGrid = layoutGrid;
  }

  document.addEventListener('DOMContentLoaded', initProjectGrid);
  document.addEventListener('astro:page-load', initProjectGrid);
</script>

<style>
  .project-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    grid-auto-rows: 250px;
    gap: 0.5rem;
    grid-auto-flow: dense;
  }

  .project-item {
    display: block;
    height: 100%;
  }

  .project-image-container {
    position: relative;
    height: 100%;
    overflow: hidden;
  }

  @media (max-width: 640px) {
    .project-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 641px) and (max-width: 768px) {
    .project-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
