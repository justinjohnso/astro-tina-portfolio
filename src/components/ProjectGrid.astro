---
import type { CollectionEntry } from 'astro:content';

export interface Props {
  projects: CollectionEntry<'projects'>[];
}

const { projects } = Astro.props;
---

<div class="project-grid" id="project-grid">
  {projects.map((project, index) => (
    <a href={`/projects/${project.slug}`} class="project-item group relative overflow-hidden" data-index={index}>
      <div class="project-image-container h-full">
        <img
          src={project.data.image || '/placeholder.jpg'}
          alt={project.data.title}
          class="project-image object-cover w-full h-full transition-transform duration-700 group-hover:scale-105"
        />
        <div class="project-overlay absolute inset-0 bg-white/30 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        <div class="project-content absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
          <div class="bg-black/60 p-3 max-w-[80%] text-center">
            <h3 class="text-white text-base sm:text-lg font-normal">
              {project.data.title}
            </h3>
            {project.data.dateCompleted && (
              <span class="text-white text-sm">
                {project.data.dateCompleted.getFullYear()}
              </span>
            )}
          </div>
        </div>
      </div>
    </a>
  ))}
</div>

<script>
  function initProjectGrid() {
    const grid = document.getElementById('project-grid');
    const allItems = Array.from(document.querySelectorAll('.project-item')) as HTMLElement[];
    if (!grid || !allItems.length) return;

    const getColumns = () => {
      if (window.innerWidth < 640) return 1;
      if (window.innerWidth < 768) return 2;
      return 3;
    };

    const patterns = {
      1: ['small', 'tall'],
      2: ['large', 'small', 'wide', 'tall', 'small', 'wide'],
      3: ['large', 'small', 'wide', 'small', 'tall', 'small', 'wide', 'tall', 'small']
    } as const;

    // Helper to calculate cells used by a size
    const getSizeCells = (size: string, columns: number): number => {
      if (columns === 1) return 1;
      if (size === 'large') return 2; // In 2+ column layouts, large takes 2 columns
      if (size === 'wide' || size === 'tall') return 1; // Each takes 1 column (tall spans 2 rows)
      return 1; // small
    };

    const layoutGrid = () => {
      const columns = getColumns();
      const visibleItems = allItems.filter(item => item.style.display !== 'none');

      // Get project data with importance/featured status
      const projectsWithImportance = visibleItems.map((item, index) => {
        const projectData = (window as any).allProjectsData?.[parseInt(item.getAttribute('data-index') || '0')];
        return {
          item,
          index,
          featured: projectData?.featured || false,
          importance: projectData?.importance || 0
        };
      });

      const totalItems = projectsWithImportance.length;
      if (totalItems === 0) return;

      // PASS 1: Mathematical Grid Construction
      // Calculate exact cell requirements for perfect fill
      const calculateCellsUsed = (large: number, wide: number, tall: number, small: number) => {
        return (large * 4) + (wide * 2) + (tall * 2) + (small * 1);
      };

      // Start with balanced distribution that favors larger items
      const targetCounts = {
        large: Math.floor(totalItems * 0.15), // 15% large (4 cells each)
        wide: Math.floor(totalItems * 0.30),  // 30% wide (2 cells each)
        tall: Math.floor(totalItems * 0.25),  // 25% tall (2 cells each)
        small: 0 // Will be calculated
      };

      // Calculate remaining items for small
      const usedItems = targetCounts.large + targetCounts.wide + targetCounts.tall;
      targetCounts.small = totalItems - usedItems;

      // Calculate total cells that would be used
      let totalCellsUsed = calculateCellsUsed(targetCounts.large, targetCounts.wide, targetCounts.tall, targetCounts.small);

      // Calculate target grid size (aim for slightly more cells than needed)
      const minRows = Math.ceil(totalCellsUsed / columns);
      const targetCells = minRows * columns;

      // Adjust distribution to perfectly fill the grid
      let cellsNeeded = targetCells - totalCellsUsed;

      // If we need more cells, convert small to larger items
      while (cellsNeeded > 0 && targetCounts.small > 0) {
        if (cellsNeeded >= 3 && targetCounts.small >= 1) {
          // Convert 1 small to 1 large (adds 3 cells)
          targetCounts.small -= 1;
          targetCounts.large += 1;
          cellsNeeded -= 3;
        } else if (cellsNeeded >= 1 && targetCounts.small >= 1) {
          // Convert 1 small to 1 wide/tall (adds 1 cell)
          targetCounts.small -= 1;
          if (Math.random() > 0.5) {
            targetCounts.wide += 1;
          } else {
            targetCounts.tall += 1;
          }
          cellsNeeded -= 1;
        } else {
          break;
        }
      }

      // If we still have excess cells, convert larger items to smaller
      while (cellsNeeded < 0) {
        if (targetCounts.large > 0) {
          targetCounts.large -= 1;
          targetCounts.small += 1;
          cellsNeeded += 3;
        } else if (targetCounts.wide > 0) {
          targetCounts.wide -= 1;
          targetCounts.small += 1;
          cellsNeeded += 1;
        } else if (targetCounts.tall > 0) {
          targetCounts.tall -= 1;
          targetCounts.small += 1;
          cellsNeeded += 1;
        } else {
          break;
        }
      }

      // Create the initial perfect grid
      const gridSizes: string[] = [];

      // Add sizes according to target counts
      for (let i = 0; i < targetCounts.large; i++) gridSizes.push('large');
      for (let i = 0; i < targetCounts.wide; i++) gridSizes.push('wide');
      for (let i = 0; i < targetCounts.tall; i++) gridSizes.push('tall');
      for (let i = 0; i < targetCounts.small; i++) gridSizes.push('small');

      // Ensure we have exactly the right number of items
      while (gridSizes.length < totalItems) gridSizes.push('small');
      while (gridSizes.length > totalItems) gridSizes.pop();

      // PASS 2: Enhanced Anti-Pattern Shuffling for Vertical Line Breaking
      const shuffledGrid = [...gridSizes];

      // Helper to detect vertical line patterns that need breaking
      const createsVerticalAlignment = (index: number, testSize: string) => {
        const row = Math.floor(index / columns);
        const col = index % columns;

        // Check for vertical line patterns (same column edges aligning)
        let verticalAlignments = 0;

        // For wide items, check if left or right edge creates vertical lines
        if (testSize === 'wide') {
          // Check column alignment (items directly above/below)
          for (let checkRow = 0; checkRow < Math.ceil(totalItems / columns); checkRow++) {
            if (checkRow === row) continue;
            const checkIndex = checkRow * columns + col;
            if (checkIndex < shuffledGrid.length) {
              const checkSize = shuffledGrid[checkIndex];
              if (checkSize === 'small' || checkSize === 'tall' || checkSize === 'wide') {
                verticalAlignments++;
              }
            }
            // Also check right edge alignment for wide items
            const rightCheckIndex = checkRow * columns + col + 1;
            if (rightCheckIndex < shuffledGrid.length && col + 1 < columns) {
              const rightCheckSize = shuffledGrid[rightCheckIndex];
              if (rightCheckSize === 'small' || rightCheckSize === 'tall') {
                verticalAlignments++;
              }
            }
          }
        }

        // For other items, check if they align with existing wide items' edges
        if (testSize === 'small' || testSize === 'tall') {
          for (let checkRow = 0; checkRow < Math.ceil(totalItems / columns); checkRow++) {
            if (checkRow === row) continue;
            const checkIndex = checkRow * columns + col;
            if (checkIndex < shuffledGrid.length) {
              const checkSize = shuffledGrid[checkIndex];
              if (checkSize === 'wide' || checkSize === 'large') {
                verticalAlignments++;
              }
            }
          }
        }

        return verticalAlignments > 1; // Flag if more than 1 alignment
      };

      // Helper to check for 4-way intersections
      const createsFourWayIntersection = (index: number, testSize: string) => {
        const row = Math.floor(index / columns);
        const col = index % columns;

        // Check if placing this size creates clean grid intersections
        const isWide = testSize === 'wide' || testSize === 'large';
        const isTall = testSize === 'tall' || testSize === 'large';

        // Look for patterns that create too many aligned edges
        let alignedEdges = 0;

        // Check horizontal neighbors for width alignment
        if (isWide) {
          const leftNeighbor = shuffledGrid[index - 1];
          const rightNeighbor = shuffledGrid[index + 2];
          if (leftNeighbor === 'wide' || leftNeighbor === 'large') alignedEdges++;
          if (rightNeighbor === 'wide' || rightNeighbor === 'large') alignedEdges++;
        }

        // Check vertical neighbors for height alignment
        if (isTall) {
          const topNeighbor = shuffledGrid[index - columns];
          const bottomNeighbor = shuffledGrid[index + columns * 2];
          if (topNeighbor === 'tall' || topNeighbor === 'large') alignedEdges++;
          if (bottomNeighbor === 'tall' || bottomNeighbor === 'large') alignedEdges++;
        }
        return false;
      };

      // Phase 1: Break vertical alignments by repositioning wide items
      for (let i = 0; i < shuffledGrid.length; i++) {
        if (shuffledGrid[i] === 'wide' && createsVerticalAlignment(i, 'wide')) {
          // Find better position for this wide item
          for (let j = 0; j < shuffledGrid.length; j++) {
            if (i !== j && shuffledGrid[j] !== 'wide' && !createsVerticalAlignment(j, 'wide')) {
              [shuffledGrid[i], shuffledGrid[j]] = [shuffledGrid[j], shuffledGrid[i]];
              break;
            }
          }
        }
      }

      // Phase 2: General anti-pattern shuffling
      for (let i = shuffledGrid.length - 1; i > 0; i--) {
        let bestJ = i;
        let lowestScore = 999;

        // Try multiple swap candidates and pick the one that creates least patterns
        const maxAttempts = Math.min(12, i); // Increased attempts for better results
        for (let attempt = 0; attempt < maxAttempts; attempt++) {
          const j = Math.floor(Math.random() * (i + 1));

          // Calculate pattern score for this swap
          let patternScore = 0;
          if (createsFourWayIntersection(i, shuffledGrid[j])) patternScore += 3;
          if (createsFourWayIntersection(j, shuffledGrid[i])) patternScore += 3;
          if (createsVerticalAlignment(i, shuffledGrid[j])) patternScore += 2;
          if (createsVerticalAlignment(j, shuffledGrid[i])) patternScore += 2;

          if (patternScore < lowestScore) {
            lowestScore = patternScore;
            bestJ = j;
          }

          // If we found a perfect swap (no patterns), use it
          if (patternScore === 0) break;
        }

        // Perform the best swap found
        [shuffledGrid[i], shuffledGrid[bestJ]] = [shuffledGrid[bestJ], shuffledGrid[i]];
      }

      // Phase 3: Strategic wide item placement for line breaking
      const wideIndices = shuffledGrid.map((size, index) => size === 'wide' ? index : -1).filter(i => i !== -1);
      wideIndices.forEach(wideIndex => {
        const row = Math.floor(wideIndex / columns);
        const col = wideIndex % columns;

        // Try to position wide items to break potential vertical lines
        // Prefer positions where they can disrupt column continuity
        let betterPosition = -1;
        let minVerticalCount = 999;

        for (let testIndex = 0; testIndex < shuffledGrid.length; testIndex++) {
          if (shuffledGrid[testIndex] === 'wide') continue;

          const testRow = Math.floor(testIndex / columns);
          const testCol = testIndex % columns;

          // Count vertical alignments this position would create
          let verticalCount = 0;
          for (let checkRow = 0; checkRow < Math.ceil(totalItems / columns); checkRow++) {
            if (checkRow === testRow) continue;
            const checkIndex = checkRow * columns + testCol;
            if (checkIndex < shuffledGrid.length && shuffledGrid[checkIndex] !== 'wide') {
              verticalCount++;
            }
          }

          if (verticalCount < minVerticalCount) {
            minVerticalCount = verticalCount;
            betterPosition = testIndex;
          }
        }

        // Swap if we found a better position
        if (betterPosition !== -1 && minVerticalCount < 2) {
          [shuffledGrid[wideIndex], shuffledGrid[betterPosition]] = [shuffledGrid[betterPosition], shuffledGrid[wideIndex]];
        }
      });

      // Phase 4: Break up clusters of large items
      for (let i = 0; i < shuffledGrid.length - 1; i++) {
        if (shuffledGrid[i] === 'large' && shuffledGrid[i + 1] === 'large') {
          for (let j = i + 2; j < shuffledGrid.length; j++) {
            if (shuffledGrid[j] !== 'large') {
              [shuffledGrid[i + 1], shuffledGrid[j]] = [shuffledGrid[j], shuffledGrid[i + 1]];
              break;
            }
          }
        }
      }

      // PASS 3: Importance-Based Assignment
      // Sort projects by importance
      const importanceOrder = projectsWithImportance
        .map((p, idx) => ({ ...p, originalIndex: idx }))
        .sort((a, b) => {
          if (a.featured !== b.featured) return b.featured ? 1 : -1;
          return b.importance - a.importance;
        });

      // Create final size assignment
      const finalSizes: string[] = new Array(totalItems).fill('small');

      // Sort grid sizes by desirability (large > wide > tall > small)
      const sizeValue = { large: 4, wide: 2, tall: 2, small: 1 };
      const sortedGridIndices = shuffledGrid
        .map((size, index) => ({ size, index }))
        .sort((a, b) => sizeValue[b.size as keyof typeof sizeValue] - sizeValue[a.size as keyof typeof sizeValue]);

      // Assign best positions to most important projects
      for (let i = 0; i < totalItems; i++) {
        const project = importanceOrder[i];
        const gridSlot = sortedGridIndices[i];
        finalSizes[project.originalIndex] = gridSlot.size;
      }

      // Apply sizes to DOM elements
      const sizeCounts = { small: 0, wide: 0, tall: 0, large: 0 };

      projectsWithImportance.forEach(({ item }, idx) => {
        const size = finalSizes[idx];
        sizeCounts[size as keyof typeof sizeCounts]++;

        const isWide = size === 'wide' || size === 'large';
        const isTall = size === 'tall' || size === 'large';
        item.style.gridColumnEnd = isWide ? 'span 2' : 'span 1';
        item.style.gridRowEnd = isTall ? 'span 2' : 'span 1';
      });

      // Debug output
      const finalCellsUsed = calculateCellsUsed(targetCounts.large, targetCounts.wide, targetCounts.tall, targetCounts.small);
      const actualGridRows = Math.ceil(finalCellsUsed / columns);
      console.log(`Mathematical Grid (${columns} cols, ${actualGridRows} rows):`, sizeCounts);
      console.log(`Target counts:`, targetCounts);
      console.log('Grid sizes distribution:', gridSizes.slice(0, 10), '...'); // Show first 10
      console.log('Shuffled distribution:', shuffledGrid.slice(0, 10), '...'); // Show first 10
      console.log('Final assignment sample:', finalSizes.slice(0, 10), '...'); // Show first 10
    };

    layoutGrid();
    window.addEventListener('resize', layoutGrid);
    (window as any).relayoutProjectGrid = layoutGrid;
  }

  document.addEventListener('DOMContentLoaded', initProjectGrid);
  document.addEventListener('astro:page-load', initProjectGrid);
</script>

<style>
  .project-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    grid-auto-rows: 250px;
    gap: 0.5rem;
    grid-auto-flow: dense;
  }

  .project-item {
    display: block;
    height: 100%;
  }

  .project-image-container {
    position: relative;
    height: 100%;
    overflow: hidden;
  }

  @media (max-width: 640px) {
    .project-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 641px) and (max-width: 768px) {
    .project-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
