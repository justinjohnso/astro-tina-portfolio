---
/**
 * Contact section component with email and social links
 *
 * Displays contact information with icons in a clean, organized layout.
 *
 * Usage:
 *   <ContactSection />
 *   <ContactSection email="custom@email.com" />
 */

import Icon from './Icon.astro';

export interface SocialLink {
  name: string;
  url: string;
  icon: string;
  username?: string;
}

export interface Props {
  email?: string;
  socialLinks?: SocialLink[];
  showHeading?: boolean;
  class?: string;
}

const defaultSocialLinks: SocialLink[] = [
  {
    name: 'GitHub',
    url: 'https://github.com/justinjohnso',
    icon: 'Github',
    username: '@justinjohnso'
  },
  {
    name: 'LinkedIn',
    url: 'https://linkedin.com/in/justinjohnso',
    icon: 'Linkedin',
    username: 'Justin Johnson'
  },
];

const {
  email = 'hello@jjohnson.art',
  socialLinks = defaultSocialLinks,
  showHeading = true,
  class: className = ''
} = Astro.props;
---

<section class={`contact-section ${className}`}>
  {showHeading && (
    <h2 class="text-2xl font-bold mb-6">Contact</h2>
  )}

  <div class="space-y-6">
    <!-- Email -->
    <div class="flex items-start gap-3">
      <div class="mt-1">
        <Icon name="Mail" size={20} class="text-gray-600 dark:text-gray-400" />
      </div>
      <div>
        <p class="text-sm text-gray-600 dark:text-gray-400 mb-1">Email</p>
        <a
          href={`mailto:${email}`}
          class="text-gray-900 dark:text-gray-100 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
        >
          {email}
        </a>
      </div>
    </div>

    <!-- Social Links -->
    {socialLinks.length > 0 && (
      <div class="flex items-start gap-3">
        <div class="mt-1">
          <Icon name="AtSign" size={20} class="text-gray-600 dark:text-gray-400" />
        </div>
        <div class="flex-1">
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-3">Social</p>
          <div class="flex flex-col gap-3">
            {socialLinks.map((link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex items-center gap-3 text-gray-900 dark:text-gray-100 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
              >
                <Icon
                  name={link.icon}
                  size={18}
                  class="text-gray-600 dark:text-gray-400 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors"
                />
                <span class="flex-1">{link.name}</span>
                {link.username && (
                  <span class="text-sm text-gray-500 dark:text-gray-500">
                    {link.username}
                  </span>
                )}
              </a>
            ))}
          </div>
        </div>
      </div>
    )}
  </div>
</section>

<style>
  .contact-section {
    max-width: 32rem;
  }
</style>
