# ============================================
# Portfolio V3 Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# --------------------------------------------
# Site Configuration
# --------------------------------------------

# Base URL for the site (used for absolute URLs in RSS, sitemaps, etc.)
# Examples: https://yourdomain.com or https://your-droplet-ip.com
PUBLIC_SITE_URL=http://localhost:4321

# Site title and metadata (optional - overrides defaults)
PUBLIC_SITE_TITLE="Your Portfolio"
PUBLIC_SITE_DESCRIPTION="Your portfolio description"


# --------------------------------------------
# TinaCMS Configuration
# --------------------------------------------

# TinaCMS Cloud credentials
# Get these from: https://app.tina.io/
NEXT_PUBLIC_TINA_CLIENT_ID=your-tina-client-id
TINA_TOKEN=your-tina-token

# TinaCMS Branch (usually 'main' or 'master')
NEXT_PUBLIC_TINA_BRANCH=main


# --------------------------------------------
# Notion Integration
# --------------------------------------------

# Notion API Integration Token
# Create at: https://www.notion.so/my-integrations
# Must have read access to your databases
NOTION_API_KEY=secret_your-notion-integration-token

# Notion Database IDs
# Get from database URLs: https://notion.so/[workspace]/[DATABASE_ID]?v=...
NOTION_PROJECTS_DB_ID=your-projects-database-id
NOTION_BLOG_DB_ID=your-blog-database-id

# Webhook Secret for Notion → Portfolio sync
# Generate a secure random string (e.g., using openssl rand -hex 32)
# Used to verify webhook signatures
NOTION_WEBHOOK_SECRET=your-webhook-secret-for-signature-verification


# --------------------------------------------
# Analytics (Umami)
# --------------------------------------------

# Umami tracking script URL
# Format: https://your-domain.com/script.js
PUBLIC_UMAMI_SRC=https://analytics.yourdomain.com/script.js

# Umami website ID
# Get from Umami dashboard after adding your site
PUBLIC_UMAMI_WEBSITE_ID=your-umami-website-id

# Umami database configuration (for Docker setup)
# These are used in docker-compose.yml for the Umami container
UMAMI_DATABASE_URL=postgresql://umami:umami@postgres:5432/umami
UMAMI_DATABASE_TYPE=postgresql

# PostgreSQL configuration for Umami
POSTGRES_USER=umami
POSTGRES_PASSWORD=change-this-secure-password
POSTGRES_DB=umami


# --------------------------------------------
# PDF Generation (Optional)
# --------------------------------------------

# Puppeteer executable path (usually auto-detected)
# Set if using custom Chrome/Chromium installation
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser


# --------------------------------------------
# Media Storage
# --------------------------------------------

# Local media storage path (relative to public/)
# Images downloaded from Notion will be saved here
MEDIA_STORAGE_PATH=media

# Maximum image size in bytes (default: 5MB)
# Images larger than this will be rejected during download
MAX_IMAGE_SIZE=5242880


# --------------------------------------------
# Rate Limiting
# --------------------------------------------

# Webhook rate limit window (milliseconds)
# Default: 60000 (1 minute)
RATE_LIMIT_WINDOW=60000

# Maximum webhook requests per window
# Default: 10 requests per minute
RATE_LIMIT_MAX_REQUESTS=10


# --------------------------------------------
# Development
# --------------------------------------------

# Node environment
NODE_ENV=development

# Enable debug logging for specific modules
# Options: notion, webhook, storage, pdf
# DEBUG=notion,webhook

# Log level (error, warn, info, debug)
LOG_LEVEL=info
