# ============================================
# Portfolio V3 Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# ============================================
# REQUIRED
# ============================================

# TinaCMS Cloud credentials (from https://app.tina.io/)
PUBLIC_TINA_CLIENT_ID=your-tina-client-id
TINA_TOKEN=your-tina-token

# Site URL (used for absolute URLs in RSS, sitemaps, etc.)
PUBLIC_SITE_URL=http://localhost:4321


# ============================================
# OPTIONAL - Notion Integration (Priority 3)
# ============================================

# Only needed if enabling Notion sync for content management
# Create integration at: https://www.notion.so/my-integrations

# Notion API Integration Token
NOTION_API_KEY=secret_your-notion-integration-token

# Notion Database IDs (get from database URLs)
NOTION_PROJECTS_DB_ID=your-projects-database-id
NOTION_BLOG_DB_ID=your-blog-database-id

# Webhook secret for Notion → Portfolio sync
# Generate with: openssl rand -hex 32
NOTION_WEBHOOK_SECRET=your-webhook-secret-for-signature-verification


# ============================================
# OPTIONAL - Analytics (Umami)
# ============================================

# Only needed if self-hosting Umami analytics on your Droplet
# Leave blank to disable analytics

# Umami tracking script URL
PUBLIC_UMAMI_SRC=https://analytics.yourdomain.com/script.js

# Umami website ID (from Umami dashboard)
PUBLIC_UMAMI_WEBSITE_ID=your-umami-website-id


# ============================================
# OPTIONAL - Media Storage
# ============================================

# Local media storage path (relative to public/)
# Default: media
MEDIA_PATH=media
