# Umami Analytics Environment Variables

# Generate with: openssl rand -base64 32
APP_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL

# Database password - Generate with: openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_WITH_OPENSSL

# Optional: Custom port (default: 3000)
# PORT=3000

# Optional: Disable update checks
# DISABLE_UPDATES=1
