{
  "name": "portfolio-astro",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "build": "tinacms build --skip-cloud-checks && astro build",
    "preview": "astro preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "tina:dev": "tinacms dev -c \"astro dev\"",
    "sync:notion": "tsx --env-file=.env scripts/sync-notion.ts",
    "sync:projects": "tsx --env-file=.env scripts/sync-notion.ts --projects",
    "sync:blog": "tsx --env-file=.env scripts/sync-notion.ts --blog",
    "push:notion": "tsx --env-file=.env scripts/push-to-notion.ts",
    "push:notion:dry": "tsx --env-file=.env scripts/push-to-notion.ts --dry-run",
    "compress:images": "tsx scripts/compress-images.ts",
    "compress:images:dry": "tsx scripts/compress-images.ts --dry-run"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/mdx": "^3.1.7",
    "@astrojs/react": "^3.6.2",
    "@astrojs/sitemap": "^3.2.1",
    "@astrojs/tailwind": "^5.1.2",
    "astro": "^4.16.18",
    "lucide-react": "^0.545.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "tinacms": "^2.2.7",
    "typescript": "^5.7.3"
  },
  "devDependencies": {
    "@notionhq/client": "^2.2.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tinacms/cli": "^1.6.8",
    "@types/node": "^22.5.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "baseline-browser-mapping": "^2.10.0",
    "eslint": "^9.16.0",
    "eslint-plugin-astro": "^1.3.1",
    "gray-matter": "^4.0.3",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "tsx": "^4.19.2"
  },
  "packageManager": "pnpm@10.30.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "better-sqlite3"
    ]
  }
}
